---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { determineCheckinStatus } from '../../lib/timeLogic';
import AstroButton from '../../components/AstroButton.astro';
import AstroCard from '../../components/AstroCard.astro';
import AstroBadge from '../../components/AstroBadge.astro';

const { token } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect(`/login?next=/checkin/${token}`);

const { data: event } = await supabase.from('events').select('*').eq('qr_token', token).single();
if (!event) return Astro.redirect('/404');

// Find the roster_member linked to this auth user (via claimed_user_id)
const { data: rosterMember } = await supabase
  .from('roster_members')
  .select('id')
  .eq('claimed_user_id', session.user.id)
  .maybeSingle();

const { data: existing } = rosterMember
  ? await supabase
      .from('attendance')
      .select('*')
      .eq('event_id', event.id)
      .eq('roster_member_id', rosterMember.id)
      .maybeSingle()
  : await supabase
      .from('attendance')
      .select('*')
      .eq('event_id', event.id)
      .eq('user_id', session.user.id)
      .maybeSingle();

let message = '';
let success = !!existing;

if (Astro.request.method === 'POST' && !existing) {
  const { status } = determineCheckinStatus({
    now: new Date(),
    opens_at: new Date(event.checkin_opens_at),
    late_after: new Date(event.late_after_at),
    closes_at: new Date(event.checkin_closes_at)
  });

  if (status === 'not_open') {
    message = 'Check-in has not opened yet.';
  } else if (status === 'closed') {
    message = 'Check-in has closed.';
  } else if (!rosterMember) {
    message = 'Your account is not linked to a roster entry yet. Please ask an admin to link you.';
  } else {
    const ip = Astro.request.headers.get('x-forwarded-for') || Astro.clientAddress;
    const ua = Astro.request.headers.get('user-agent');

    const { error } = await supabase.from('attendance').insert({
      event_id: event.id,
      user_id: session.user.id,
      roster_member_id: rosterMember.id,
      status: status,
      ip_address: ip,
      user_agent: ua
    });

    if (error) {
      message = error.message;
    } else {
      success = true;
      message = 'Attendance submitted successfully!';
    }
  }
}

const currentStatus = determineCheckinStatus({
  now: new Date(),
  opens_at: new Date(event.checkin_opens_at),
  late_after: new Date(event.late_after_at),
  closes_at: new Date(event.checkin_closes_at)
});
---
<Layout title={`Check-in: ${event.title}`}>
  <main class="flex items-center justify-center min-h-[calc(100vh-3.5rem)] p-4">
    <AstroCard className="max-w-md w-full p-8 text-center">
      <div class="mb-6">
        <div class="inline-flex p-3 rounded-full bg-primary/10 text-primary mb-4">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-12a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
        </div>
        <h1 class="text-2xl font-semibold tracking-tight">{event.title}</h1>
        <p class="text-muted-foreground mt-1 text-sm">Event attendance verification</p>
      </div>

      {success ? (
        <div class="space-y-5">
          <div class="bg-emerald-50 border border-emerald-200 p-5 rounded-2xl text-emerald-700">
            <div class="flex justify-center mb-2">
              <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <p class="text-base font-semibold">You're checked in</p>
            {existing && <p class="text-sm opacity-80 mt-1">Recorded at {new Date(existing.checked_in_at).toLocaleTimeString()}</p>}
            {message && <p class="mt-3 text-sm">{message}</p>}
          </div>
          <a href="/dashboard" class="block">
            <AstroButton variant="outline" className="w-full">
              Return to dashboard
            </AstroButton>
          </a>
        </div>
      ) : (
        <div class="space-y-5">
          <p class="text-sm text-muted-foreground leading-relaxed">Confirm your presence for <span class="font-medium text-foreground">{event.title}</span>.</p>

          {message && (
            <div class="bg-destructive/10 border border-destructive/30 p-3 rounded-2xl text-destructive text-sm">
              {message}
            </div>
          )}

          <div class="py-4 border-y flex items-center justify-center">
            {currentStatus.status === 'not_open' && (
              <AstroBadge variant="warning">
                Opens at {new Date(event.checkin_opens_at).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
              </AstroBadge>
            )}
            {currentStatus.status === 'closed' && (
              <AstroBadge variant="destructive">
                Check-in is closed
              </AstroBadge>
            )}
            {(currentStatus.status === 'present' || currentStatus.status === 'late') && (
              <div class="flex items-center gap-2">
                <span class="relative flex h-2.5 w-2.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                </span>
                <span class="text-sm font-medium text-emerald-700">Check-in is live</span>
              </div>
            )}
          </div>

          {(currentStatus.status === 'present' || currentStatus.status === 'late') && (
            <form method="post">
              <AstroButton type="submit" size="lg" className="w-full h-14 text-base font-semibold">
                <span class="flex flex-col items-center">
                  <span>Submit attendance</span>
                  {currentStatus.status === 'late' && <span class="text-[10px] uppercase tracking-wider opacity-70 mt-0.5">Status: late</span>}
                  {currentStatus.status === 'present' && <span class="text-[10px] uppercase tracking-wider opacity-70 mt-0.5">Status: on time</span>}
                </span>
              </AstroButton>
            </form>
          )}
        </div>
      )}
    </AstroCard>
  </main>
</Layout>
