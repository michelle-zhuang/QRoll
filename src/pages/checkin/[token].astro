---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseClient } from '../../lib/supabase';
import { determineCheckinStatus, formatPacificTime, formatPacificDateTime } from '../../lib/timeLogic';
import AstroButton from '../../components/AstroButton.astro';
import AstroCard from '../../components/AstroCard.astro';
import AstroBadge from '../../components/AstroBadge.astro';
import { RosterOnboardingCard } from '../../components/RosterOnboardingCard';
import {
  findFuzzyMatches,
  getAllUnclaimedMembers,
} from '../../lib/onboarding';
import { calculateDistance } from '../../lib/geofencing';

const { token } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect(`/login?next=/checkin/${token}`);

// --- Auto-link by name if not yet linked ----------------------------------
// We attempt this on every page load so that a user who just signed up via
// Google (and whose profile trigger ran) also gets the benefit on first visit.
let { data: event } = await supabase.from('events').select('*').eq('qr_token', token).maybeSingle();
let nextOccurrence: { title: string; checkin_opens_at: string } | null = null;

if (!event) {
  const { data: series } = await supabase
    .from('event_series')
    .select('id, title')
    .eq('qr_token', token)
    .maybeSingle();
  if (series) {
    const nowIso = new Date().toISOString();
    const { data: active } = await supabase
      .from('events')
      .select('*')
      .eq('series_id', series.id)
      .is('cancelled_at', null)
      .lte('checkin_opens_at', nowIso)
      .gte('checkin_closes_at', nowIso)
      .order('checkin_closes_at', { ascending: true })
      .limit(1)
      .maybeSingle();
    if (active) {
      event = active;
    } else {
      const { data: next } = await supabase
        .from('events')
        .select('title, checkin_opens_at')
        .eq('series_id', series.id)
        .is('cancelled_at', null)
        .gt('checkin_opens_at', nowIso)
        .order('checkin_opens_at', { ascending: true })
        .limit(1)
        .maybeSingle();
      nextOccurrence = next ?? { title: series.title, checkin_opens_at: '' };
    }
  }
}

if (!event && !nextOccurrence) return Astro.redirect('/404');

// Attempt to auto-link this user to a roster member if not already claimed.
let { data: rosterMember } = await supabase
  .from('roster_members')
  .select('id')
  .eq('claimed_user_id', session.user.id)
  .maybeSingle();



// Check if member dashboard is allowed and if user is admin
const [settingRes, profileRes] = await Promise.all([
  supabase.from('app_settings').select('value').eq('key', 'allow_member_dashboard').maybeSingle(),
  supabase.from('profiles').select('role').eq('id', session.user.id).maybeSingle()
]);

const allowMemberDashboard = settingRes?.data ? (settingRes.data.value === true || settingRes.data.value === 'true') : false;
const isAdmin = profileRes?.data?.role === 'admin';
const showDashboardButton = isAdmin || allowMemberDashboard;

// If still unlinked, gather data for the onboarding card.
const userFullName =
  session.user.user_metadata?.full_name ||
  session.user.user_metadata?.name ||
  '';
const showOnboardingCard = !rosterMember;
const fuzzyMatches = showOnboardingCard
  ? await findFuzzyMatches(supabase, userFullName)
  : [];
const allUnclaimedMembers = showOnboardingCard
  ? await getAllUnclaimedMembers(supabase)
  : [];

const { data: existing } = event
  ? rosterMember
    ? await supabase
        .from('attendance')
        .select('*')
        .eq('event_id', event.id)
        .eq('roster_member_id', rosterMember.id)
        .maybeSingle()
    : await supabase
        .from('attendance')
        .select('*')
        .eq('event_id', event.id)
        .eq('user_id', session.user.id)
        .maybeSingle()
  : { data: null } as { data: null };

let message = '';
let success = !!existing;

if (event && Astro.request.method === 'POST' && !existing) {
  const { status } = determineCheckinStatus({
    now: new Date(),
    opens_at: new Date(event.checkin_opens_at),
    late_after: new Date(event.late_after_at),
    closes_at: new Date(event.checkin_closes_at)
  });

  if (status === 'not_open') {
    message = 'Check-in has not opened yet.';
  } else if (status === 'closed') {
    message = 'Check-in has closed.';
  } else if (!rosterMember) {
    // The onboarding card is shown below — skip the generic error.
  } else {
    const formData = await Astro.request.formData();
    const clientLat = formData.get('client_latitude') ? parseFloat(formData.get('client_latitude') as string) : null;
    const clientLon = formData.get('client_longitude') ? parseFloat(formData.get('client_longitude') as string) : null;
    const clientAcc = formData.get('client_accuracy') ? parseFloat(formData.get('client_accuracy') as string) : null;

    let verification_method: 'gps' | 'ip' | 'none' = 'none';
    let verification_status: 'verified' | 'verified_ip' | 'out_of_bounds' | 'out_of_bounds_ip' | 'unverified' = 'unverified';
    let calculated_distance_meters: number | null = null;
    let ipLat: number | null = null;
    let ipLon: number | null = null;

    if (clientLat !== null && clientLon !== null && !isNaN(clientLat) && !isNaN(clientLon)) {
      verification_method = 'gps';
      if (event.geofence_enabled && event.latitude !== null && event.longitude !== null) {
        calculated_distance_meters = calculateDistance(clientLat, clientLon, event.latitude, event.longitude);
        const maxRadius = event.geofence_radius_meters + Math.min(clientAcc || 0, 30);
        verification_status = calculated_distance_meters <= maxRadius ? 'verified' : 'out_of_bounds';
      }
    } else {
      // Fallback to IP geolocation
      const headerLat = Astro.request.headers.get('x-vercel-ip-latitude');
      const headerLon = Astro.request.headers.get('x-vercel-ip-longitude');
      if (headerLat && headerLon) {
        ipLat = parseFloat(headerLat);
        ipLon = parseFloat(headerLon);
        if (!isNaN(ipLat) && !isNaN(ipLon)) {
          verification_method = 'ip';
          if (event.geofence_enabled && event.latitude !== null && event.longitude !== null) {
            calculated_distance_meters = calculateDistance(ipLat, ipLon, event.latitude, event.longitude);
            verification_status = calculated_distance_meters <= 20000 ? 'verified_ip' : 'out_of_bounds_ip';
          }
        }
      }
    }

    const ip = Astro.request.headers.get('x-forwarded-for') || Astro.clientAddress;
    const ua = Astro.request.headers.get('user-agent');

    const { error } = await supabase.from('attendance').insert({
      event_id: event.id,
      user_id: session.user.id,
      roster_member_id: rosterMember.id,
      status: status,
      ip_address: ip,
      user_agent: ua,
      verification_method,
      verification_status,
      client_latitude: clientLat,
      client_longitude: clientLon,
      client_accuracy: clientAcc,
      calculated_distance_meters,
      ip_latitude: ipLat,
      ip_longitude: ipLon,
      checked_in_at: new Date().toISOString()
    });

    if (error) {
      message = error.message;
    } else {
      success = true;
      message = 'Attendance submitted successfully!';
    }
  }
}

const currentStatus = event
  ? determineCheckinStatus({
      now: new Date(),
      opens_at: new Date(event.checkin_opens_at),
      late_after: new Date(event.late_after_at),
      closes_at: new Date(event.checkin_closes_at)
    })
  : null;

const pageTitle = event ? event.title : (nextOccurrence?.title ?? 'Check-in');
---
<Layout title={`Check-in: ${pageTitle}`}>
  <main class="flex items-center justify-center min-h-[calc(100vh-3.5rem)] p-4">
    <AstroCard className="max-w-md w-full p-8 text-center">
      <div class="mb-6">
        <div class="inline-flex p-3 rounded-full bg-primary/10 text-primary mb-4">
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-12a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
        </div>
        <h1 class="text-2xl font-bold tracking-tight text-balance">{pageTitle}</h1>
        <p class="text-muted-foreground mt-2 text-sm">Event attendance verification</p>
      </div>

      {!event && nextOccurrence ? (
        <div class="space-y-6">
          <div class="bg-[#F5EFFA]/50 border border-[#ECE6F2] p-6 rounded-2xl flex flex-col items-center gap-4 text-center">
            <img src="/sad_cat.svg" alt="No active check-in" class="h-32 md:h-36 w-auto select-none pointer-events-none animate-cat-float" aria-hidden="true" />
            <div>
              <p class="text-lg font-bold text-[#2F2738]">No live check-in right now</p>
              {nextOccurrence.checkin_opens_at ? (
                <p class="text-sm text-[#6B6377] mt-1">
                  Next session opens {formatPacificDateTime(nextOccurrence.checkin_opens_at)}
                </p>
              ) : (
                <p class="text-sm text-[#6B6377] mt-1">No upcoming sessions are scheduled.</p>
              )}
            </div>
          </div>
          {showDashboardButton && (
            <a href="/dashboard" class="block">
              <AstroButton variant="outline" className="w-full">Return to dashboard</AstroButton>
            </a>
          )}
        </div>
      ) : success ? (
        <div class="space-y-6">
          <div class="bg-[#D0F4DE]/20 border border-[#D0F4DE]/40 p-6 rounded-2xl flex flex-col items-center gap-4 animate-sticker-pop text-center">
            <img src="/happy_cat.svg" alt="Success!" class="h-32 md:h-36 w-auto select-none pointer-events-none" aria-hidden="true" />
            <div>
              <p class="text-lg font-bold text-[#2F2738]">You're checked in!</p>
              {existing && <p class="text-sm text-[#6B6377] mt-1">Recorded at {formatPacificTime(existing.checked_in_at)}</p>}
              {message && <p class="mt-3 text-sm text-[#6B6377]">{message}</p>}
            </div>
          </div>
          {showDashboardButton && (
            <a href="/dashboard" class="block">
              <AstroButton variant="outline" className="w-full">
                Return to dashboard
              </AstroButton>
            </a>
          )}
        </div>
      ) : showOnboardingCard ? (
        <div class="space-y-5 text-left">
          <div>
            <p class="text-base font-semibold">Link your account</p>
            <p class="text-sm text-muted-foreground mt-1">
              Your account isn't linked to a roster entry yet. Choose a match below,
              search the full roster, or create a new entry to continue.
            </p>
          </div>
          <RosterOnboardingCard
            fuzzyMatches={fuzzyMatches}
            allUnclaimed={allUnclaimedMembers}
            redirectTo={`/checkin/${token}`}
            client:load
          />
        </div>
      ) : (
        <div class="space-y-6">
          <p class="text-sm text-muted-foreground leading-relaxed">Confirm your presence for <span class="font-medium text-foreground">{event!.title}</span>.</p>

          {message && (
            <div class="bg-destructive/10 border border-destructive/30 p-4 rounded-xl text-destructive text-sm">
              {message}
            </div>
          )}

          <div class="py-4 border-y flex items-center justify-center">
            {currentStatus?.status === 'not_open' && (
              <AstroBadge variant="warning">
                Opens at {formatPacificTime(event!.checkin_opens_at)}
              </AstroBadge>
            )}
            {currentStatus?.status === 'closed' && (
              <AstroBadge variant="destructive">
                Check-in is closed
              </AstroBadge>
            )}
            {(currentStatus?.status === 'present' || currentStatus?.status === 'late') && (
              <div class="flex items-center gap-2">
                <span class="relative flex h-2.5 w-2.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                </span>
                <span class="text-sm font-medium text-emerald-700">Check-in is live</span>
              </div>
            )}
          </div>

          {(currentStatus?.status === 'present' || currentStatus?.status === 'late') && (
            <form method="post" id="checkin-form">
              <input type="hidden" name="client_latitude" id="client_latitude" />
              <input type="hidden" name="client_longitude" id="client_longitude" />
              <input type="hidden" name="client_accuracy" id="client_accuracy" />
              <input type="hidden" name="geolocation_error" id="geolocation_error" />
              <AstroButton type="submit" size="lg" className="w-full h-14 text-base font-semibold" id="submit-btn">
                <span class="flex flex-col items-center">
                  <span>Submit attendance</span>
                  {currentStatus?.status === 'late' && <span class="text-[10px] uppercase tracking-wider opacity-70 mt-0.5">Status: late</span>}
                  {currentStatus?.status === 'present' && <span class="text-[10px] uppercase tracking-wider opacity-70 mt-0.5">Status: on time</span>}
                </span>
              </AstroButton>
            </form>
          )}
        </div>
      )}
    </AstroCard>
  </main>
  <script is:inline>
    const form = document.getElementById('checkin-form');
    const submitBtn = document.getElementById('submit-btn');
    if (form && document.getElementById('client_latitude')) {
      if (submitBtn) {
        submitBtn.disabled = true;
        const textSpan = submitBtn.querySelector('span > span');
        if (textSpan) {
          submitBtn.dataset.originalText = textSpan.innerText;
          textSpan.innerText = 'Acquiring location...';
        }
      }

      function enableSubmit() {
        if (submitBtn) {
          submitBtn.disabled = false;
          const textSpan = submitBtn.querySelector('span > span');
          if (textSpan && submitBtn.dataset.originalText) {
            textSpan.innerText = submitBtn.dataset.originalText;
          }
        }
      }

      if (navigator.geolocation) {
        navigator.geolocation.getCurrentPosition(
          (position) => {
            document.getElementById('client_latitude').value = position.coords.latitude;
            document.getElementById('client_longitude').value = position.coords.longitude;
            document.getElementById('client_accuracy').value = position.coords.accuracy;
            enableSubmit();
          },
          (error) => {
            const errorTypes = { 1: 'PERMISSION_DENIED', 2: 'POSITION_UNAVAILABLE', 3: 'TIMEOUT' };
            document.getElementById('geolocation_error').value = errorTypes[error.code] || 'UNKNOWN_ERROR';
            enableSubmit();
          },
          { enableHighAccuracy: true, timeout: 6000 }
        );
      } else {
        document.getElementById('geolocation_error').value = 'GEOLOCATION_NOT_SUPPORTED';
        enableSubmit();
      }
    }
  </script>
</Layout>
