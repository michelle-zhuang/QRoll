---
import Layout from '../layouts/Layout.astro';
import { createSupabaseClient } from '../lib/supabase';
import AstroCard from '../components/AstroCard.astro';
import AstroBadge from '../components/AstroBadge.astro';
import AstroButton from '../components/AstroButton.astro';
import { AttendanceMatrix } from '../components/AttendanceMatrix';
import { PerEventStackedBars, TopAttendeesChart } from '../components/DashboardCharts';
import type { AttendanceData, AttendanceStatus, AttendanceRecord } from '../lib/attendanceTypes';
import { Users, Calendar } from 'lucide-react';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

let selectedTeamId = Astro.cookies.get('qroll_team_id')?.value || null;
let selectedCompanyId = Astro.cookies.get('qroll_company_id')?.value || null;

// 1. Initial parallel query to resolve user profile and team access scope
const [profileRes, memberTeamsRes, adminCompaniesRes] = await Promise.all([
  supabase.from('profiles').select('*').eq('id', session.user.id).maybeSingle(),
  supabase.from('team_members').select('team_id, teams (id, name, company_id)').eq('user_id', session.user.id),
  supabase.from('company_members').select('company_id, role').eq('user_id', session.user.id).eq('role', 'admin')
]);

let profile = profileRes.data;
if (!profile) {
  const { data: newProfile, error } = await supabase
    .from('profiles')
    .insert({
      id: session.user.id,
      email: session.user.email,
      full_name: session.user.user_metadata?.full_name || null
    })
    .select()
    .single();
  if (!error) profile = newProfile;
}

const memberTeams = memberTeamsRes.data || [];
const adminCompanies = adminCompaniesRes.data || [];
const isGlobalAdmin = profile?.role === 'admin';

// 2. Fetch teams for companies they admin
let adminTeams: any[] = [];
if (isGlobalAdmin) {
  const { data } = await supabase.from('teams').select('id, name, company_id');
  adminTeams = data || [];
} else if (adminCompanies.length > 0) {
  const { data } = await supabase
    .from('teams')
    .select('id, name, company_id')
    .in('company_id', adminCompanies.map(c => c.company_id));
  adminTeams = data || [];
}

// 3. Resolve all accessible teams
const accessibleTeamsMap = new Map<string, { id: string; name: string; company_id: string }>();
memberTeams.forEach((m: any) => {
  if (m.teams) {
    accessibleTeamsMap.set(m.teams.id, {
      id: m.teams.id,
      name: m.teams.name,
      company_id: m.teams.company_id
    });
  }
});
adminTeams.forEach((t: any) => {
  accessibleTeamsMap.set(t.id, t);
});

const accessibleTeams = [...accessibleTeamsMap.values()];

let hasNoTeams = false;

if (accessibleTeams.length > 0) {
  const teamIds = accessibleTeams.map(t => t.id);
  if (!selectedTeamId || !teamIds.includes(selectedTeamId)) {
    selectedTeamId = accessibleTeams[0].id;
    selectedCompanyId = accessibleTeams[0].company_id;
    Astro.cookies.set('qroll_team_id', selectedTeamId, { path: '/' });
    Astro.cookies.set('qroll_company_id', selectedCompanyId, { path: '/' });
  } else {
    const found = accessibleTeams.find(t => t.id === selectedTeamId);
    selectedCompanyId = found ? found.company_id : null;
  }
} else {
  hasNoTeams = true;
}

// Company-scoped admin check
let isAdmin = isGlobalAdmin;
if (!isAdmin && selectedCompanyId) {
  const { data: member } = await supabase
    .from('company_members')
    .select('role')
    .eq('company_id', selectedCompanyId)
    .eq('user_id', session.user.id)
    .maybeSingle();
  isAdmin = member?.role === 'admin';
}

const isRestricted = !isAdmin;

let events: any[] = [];
let roster: any[] = [];
let attendance: any[] = [];

if (!isRestricted) {
  const [eventsRes, rosterRes] = await Promise.all([
    supabase.from('events').select('id, title, starts_at, checkin_closes_at, cancelled_at').eq('team_id', selectedTeamId).order('starts_at', { ascending: true }),
    supabase.from('team_members').select('id, full_name, user_id').eq('team_id', selectedTeamId).order('full_name', { ascending: true })
  ]);
  
  events = eventsRes.data || [];
  roster = rosterRes.data || [];
  
  const eventIds = events.map(e => e.id);
  if (eventIds.length > 0) {
    let page = 0;
    const pageSize = 1000;
    while (true) {
      const { data: attendanceData, error } = await supabase
        .from('attendance')
        .select('event_id, team_member_id, status, note, checked_in_at, verification_status, verification_method, calculated_distance_meters')
        .in('event_id', eventIds)
        .range(page * pageSize, (page + 1) * pageSize - 1);
      
      if (error || !attendanceData || attendanceData.length === 0) break;
      attendance.push(...attendanceData);
      if (attendanceData.length < pageSize) break;
      page++;
    }
  }
}

const linkedMember = roster.find(m => m.user_id === session.user.id);
const displayName = linkedMember?.full_name || profile?.full_name || profile?.email || session.user.email;

// Map event_id -> ISO date (YYYY-MM-DD) using starts_at in America/Los_Angeles timezone
const dateByEvent: Record<string, string> = {};
const datesSet = new Set<string>();
const formatter = new Intl.DateTimeFormat('en-US', {
  timeZone: 'America/Los_Angeles',
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});

events.forEach(e => {
  const d = new Date(e.starts_at);
  const parts = formatter.formatToParts(d);
  const year = parts.find(p => p.type === 'year')!.value;
  const month = parts.find(p => p.type === 'month')!.value;
  const day = parts.find(p => p.type === 'day')!.value;
  const localDateStr = `${year}-${month}-${day}`;

  dateByEvent[e.id] = localDateStr;
  datesSet.add(localDateStr);
});
const dates = [...datesSet].sort();

const nowStr = new Date().toISOString();

// Group existing attendance by team_member_id and event_id for fast lookup
const attendanceMap = new Map<string, typeof attendance[0]>();
attendance.forEach(a => {
  if (a.team_member_id) {
    attendanceMap.set(`${a.team_member_id}:${a.event_id}`, a);
  }
});

const filteredRoster = isAdmin
  ? roster
  : roster.filter(m => m.user_id === session.user.id);

// Build matrix data, generating 'absent' in-memory for missing records of closed events
const recordsByMember: Record<string, AttendanceRecord[]> = {};
filteredRoster.forEach(m => {
  recordsByMember[m.id] = [];
  events.forEach(e => {
    const date = dateByEvent[e.id];
    if (!date) return;

    const key = `${m.id}:${e.id}`;
    const a = attendanceMap.get(key);

    if (a) {
      const status = (a.status === 'on_time' ? 'present' : a.status) as AttendanceStatus;
      recordsByMember[m.id].push({
        date,
        status,
        reason: a.note ?? null,
        verification_status: (a as any).verification_status,
        verification_method: (a as any).verification_method,
        calculated_distance_meters: (a as any).calculated_distance_meters,
        checked_in_at: a.checked_in_at
      });
    } else {
      // If event checkin has closed, default to 'absent' in-memory fallback
      const isClosed = e.checkin_closes_at && e.checkin_closes_at < nowStr && !e.cancelled_at;
      if (isClosed) {
        recordsByMember[m.id].push({
          date,
          status: 'absent',
          reason: null,
          verification_status: undefined,
          verification_method: undefined,
          calculated_distance_meters: null,
          checked_in_at: undefined
        });
      }
    }
  });
});

const data: AttendanceData = {
  dates,
  attendees: filteredRoster.map(m => ({
    id: m.id,
    name: m.full_name,
    records: recordsByMember[m.id] || [],
  })),
};

// Stats
type AttendeeStat = {
  id: string;
  name: string;
  present: number;
  late: number;
  absent: number;
  total: number;
  attendanceRate: number;
};
const stats: AttendeeStat[] = data.attendees.map(a => {
  const present = a.records.filter(r => r.status === 'present').length;
  const late = a.records.filter(r => r.status === 'late').length;
  const absent = a.records.filter(r => r.status === 'absent').length;
  const total = a.records.length;
  const attendanceRate = total > 0 ? Math.round(((present + late) / total) * 100) : 0;
  return { id: a.id, name: a.name, present, late, absent, total, attendanceRate };
});

const totalPresent = stats.reduce((s, a) => s + a.present, 0);
const totalLate = stats.reduce((s, a) => s + a.late, 0);
const totalAbsent = stats.reduce((s, a) => s + a.absent, 0);
const totalRecords = totalPresent + totalLate + totalAbsent;
const onTimeRate = totalRecords > 0 ? Math.round((totalPresent / totalRecords) * 100) : 0;

const topAttendees = [...stats].sort((a, b) => (b.present + b.late) - (a.present + a.late)).slice(0, 8);
const leastAttendees = [...stats]
  .filter(s => s.total > 0)
  .sort((a, b) => (a.present + a.late) - (b.present + b.late))
  .slice(0, 5);
const mostLate = [...stats].filter(s => s.late > 0).sort((a, b) => b.late - a.late).slice(0, 5);

const perEventStats = dates.map(d => {
  let p = 0, l = 0, ab = 0;
  data.attendees.forEach(a => {
    const rec = a.records.find(r => r.date === d);
    if (rec) {
      if (rec.status === 'present') p++;
      else if (rec.status === 'late') l++;
      else if (rec.status === 'absent') ab++;
    }
  });
  return { date: d, present: p, late: l, absent: ab, total: p + l + ab };
});

const hasData = filteredRoster.length > 0 && events.length > 0;
---
<Layout title="Dashboard">
  <main class="max-w-7xl mx-auto p-6 md:p-8">
    {hasNoTeams ? (
      <div class="flex items-center justify-center min-h-[50vh] py-12">
        <AstroCard className="max-w-md w-full p-8 text-center">
          <div class="inline-flex p-3 rounded-full bg-muted mb-4">
            <Calendar className="w-8 h-8 text-muted-foreground" />
          </div>
          <h1 class="text-xl font-bold text-foreground">Welcome to QRoll</h1>
          <p class="text-sm text-muted-foreground mt-2 leading-relaxed">
            You are not currently a member of any team. To get started, please request a team invite link from your organization's administrator.
          </p>
          {isGlobalAdmin && (
            <div class="mt-6">
              <a href="/companies">
                <AstroButton className="w-full">Manage Companies & Teams</AstroButton>
              </a>
            </div>
          )}
        </AstroCard>
      </div>
    ) : isRestricted ? (
      <div class="flex items-center justify-center min-h-[50vh] py-12">
        <AstroCard className="max-w-md w-full p-8 text-center">
          <div class="inline-flex p-3 rounded-full bg-amber-100 text-amber-700 mb-4">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m0-6h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h1 class="text-xl font-bold text-foreground">Access Restricted</h1>
          <p class="text-sm text-muted-foreground mt-2">
            The attendance dashboard is currently restricted to administrators. Please contact your organization leader for details.
          </p>
        </AstroCard>
      </div>
    ) : (
      <>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
          <div>
            <p class="text-sm text-muted-foreground">Welcome back,</p>
            <h1 class="text-3xl font-semibold tracking-tight mt-0.5 break-all">{displayName}</h1>
          </div>
          {isAdmin && (
            <div class="flex items-center gap-2">
              <a href="/admin/roster">
                <AstroButton variant="outline" size="sm">
                  <Users className="w-4 h-4" />
                  Roster
                </AstroButton>
              </a>
              <a href="/admin">
                <AstroButton variant="outline" size="sm">
                  <Calendar className="w-4 h-4" />
                  Manage events
                </AstroButton>
              </a>
            </div>
          )}
        </div>

        {!hasData ? (
          <AstroCard className="p-12 text-center">
            <div class="inline-flex p-3 rounded-full bg-muted mb-4">
              <Calendar className="w-6 h-6 text-muted-foreground" />
            </div>
            <p class="text-base font-medium">No attendance data yet</p>
            <p class="text-sm text-muted-foreground mt-1">{isAdmin ? 'Create your first event or seed the roster to get started.' : 'Once events are recorded you\'ll see analytics here.'}</p>
          </AstroCard>
        ) : (
          <>
            <!-- Top stats banner (no individual cards) -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 border-y border-border mb-8 bg-card/10 px-6 rounded-xl">
              <div class="flex flex-col gap-1 first:pl-0 md:border-r border-border md:pr-6 last:border-r-0">
                <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Events</span>
                <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{dates.length}</span>
              </div>
              <div class="flex flex-col gap-1 md:border-r border-border md:px-6 last:border-r-0">
                <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Roster</span>
                <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{filteredRoster.length}</span>
              </div>
              <div class="flex flex-col gap-1 md:border-r border-border md:px-6 last:border-r-0">
                <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">On-time rate</span>
                <div class="flex items-baseline gap-1.5">
                  <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{onTimeRate}%</span>
                </div>
                <div class="mt-2 h-1.5 w-full bg-muted rounded-full overflow-hidden">
                  <div class="h-full bg-emerald-400 rounded-full" style={`width:${onTimeRate}%`}></div>
                </div>
              </div>
              <div class="flex flex-col gap-1 md:pl-6">
                <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Late / Absent</span>
                <div class="flex items-baseline gap-1 text-3xl font-bold tracking-tight text-foreground tabular-nums">
                  <span>{totalLate}</span>
                  <span class="text-xl font-normal text-muted-foreground">/</span>
                  <span class="text-muted-foreground">{totalAbsent}</span>
                </div>
              </div>
            </div>

            <!-- Attendance Matrix -->
            <AstroCard className="p-6 mb-8 overflow-hidden">
              <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
                <div>
                  <h2 class="text-lg font-semibold tracking-tight">Attendance matrix</h2>
                  <p class="text-xs text-muted-foreground mt-0.5">{isAdmin ? 'Hover for details, click any cell to add or edit a note.' : 'Hover any cell for status and notes.'}</p>
                </div>
                <div class="flex items-center gap-3 text-xs flex-wrap">
                  <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-emerald-300"></span>Present</span>
                  <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-amber-300"></span>Late</span>
                  <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-rose-300"></span>Absent</span>
                  <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-muted"></span>N/A</span>
                  <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-foreground/40"></span>Has note</span>
                </div>
              </div>

              <AttendanceMatrix data={data} canEditNotes={isAdmin} noteApiUrl={isAdmin ? "/api/attendance/note" : undefined} client:load />
            </AstroCard>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
              {isAdmin && (
                <AstroCard className="p-6">
                  <div class="flex items-center justify-between mb-5">
                    <div>
                      <h2 class="text-lg font-semibold tracking-tight">Top attendees</h2>
                      <p class="text-xs text-muted-foreground mt-0.5">Stacked: present / late / absent</p>
                    </div>
                    <AstroBadge variant="secondary">{roster.length} total</AstroBadge>
                  </div>
                  <TopAttendeesChart data={topAttendees.map(a => ({ name: a.name, present: a.present, late: a.late, absent: a.absent }))} client:load />
                </AstroCard>
              )}

              <AstroCard className={isAdmin ? "p-6" : "p-6 lg:col-span-2"}>
                <div class="mb-5">
                  <h2 class="text-lg font-semibold tracking-tight">Attendance per event</h2>
                  <p class="text-xs text-muted-foreground mt-0.5">Stacked: present / late / absent</p>
                </div>
                <PerEventStackedBars data={perEventStats} client:load />
              </AstroCard>
            </div>

            <!-- Roster Insights Panel -->
            {isAdmin && (
              <AstroCard className="p-6 mb-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
                  <div class="border-b md:border-b-0 md:border-r border-border pb-6 md:pb-0 md:pr-8">
                    <div class="mb-5">
                      <h2 class="text-lg font-semibold tracking-tight">Least active</h2>
                      <p class="text-xs text-muted-foreground mt-0.5">Lowest attendance count</p>
                    </div>
                    <ul class="space-y-2">
                      {leastAttendees.map(a => (
                        <li class="flex items-center justify-between gap-3 p-3 rounded-2xl bg-muted/40 hover-row-premium">
                          <div class="min-w-0">
                            <p class="text-sm font-medium truncate">{a.name}</p>
                            <p class="text-xs text-muted-foreground">{a.absent} missed · {a.attendanceRate}% rate</p>
                          </div>
                          <AstroBadge variant="outline">{a.present + a.late}/{a.total}</AstroBadge>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="pt-6 md:pt-0 md:pl-8">
                    <div class="mb-5">
                      <h2 class="text-lg font-semibold tracking-tight">Most late arrivals</h2>
                      <p class="text-xs text-muted-foreground mt-0.5">Total late check-ins</p>
                    </div>
                    {mostLate.length === 0 ? (
                      <p class="text-sm text-muted-foreground py-8 text-center">No late check-ins recorded.</p>
                    ) : (
                      <ul class="space-y-2">
                        {mostLate.map(a => (
                          <li class="flex items-center justify-between gap-3 p-3 rounded-2xl bg-muted/40 hover-row-premium">
                            <div class="min-w-0">
                              <p class="text-sm font-medium truncate">{a.name}</p>
                              <p class="text-xs text-muted-foreground">{a.present} present · {a.absent} absent</p>
                            </div>
                            <AstroBadge variant="warning">{a.late} late</AstroBadge>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </div>
              </AstroCard>
            )}
          </>
        )}
      </>
    )}
  </main>

</Layout>
