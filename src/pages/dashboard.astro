---
import Layout from '../layouts/Layout.astro';
import { createSupabaseClient } from '../lib/supabase';
import AstroCard from '../components/AstroCard.astro';
import AstroBadge from '../components/AstroBadge.astro';
import AstroButton from '../components/AstroButton.astro';
import { AttendanceMatrix } from '../components/AttendanceMatrix';
import { PerEventStackedBars, TopAttendeesChart } from '../components/DashboardCharts';
import type { AttendanceData, AttendanceStatus } from '../lib/attendanceTypes';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

let { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', session.user.id)
  .single();

if (!profile) {
  const { data: newProfile, error } = await supabase
    .from('profiles')
    .insert({
      id: session.user.id,
      email: session.user.email,
      full_name: session.user.user_metadata?.full_name || null
    })
    .select()
    .single();
  if (!error) profile = newProfile;
}

const displayName = profile?.full_name || profile?.email || session.user.email;
const isAdmin = profile?.role === 'admin';

// Pull all events + roster + attendance
const [eventsRes, rosterRes, attendanceRes] = await Promise.all([
  supabase.from('events').select('id, title, starts_at').order('starts_at', { ascending: true }),
  supabase.from('roster_members').select('id, full_name, claimed_user_id').order('full_name', { ascending: true }),
  supabase.from('attendance').select('event_id, roster_member_id, status, note, checked_in_at')
]);

const events = eventsRes.data || [];
const roster = rosterRes.data || [];
const attendance = attendanceRes.data || [];

// Map event_id -> ISO date (YYYY-MM-DD) using starts_at in America/Los_Angeles timezone
const dateByEvent: Record<string, string> = {};
const datesSet = new Set<string>();
events.forEach(e => {
  const d = new Date(e.starts_at);
  const formatter = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/Los_Angeles',
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
  const parts = formatter.formatToParts(d);
  const year = parts.find(p => p.type === 'year')!.value;
  const month = parts.find(p => p.type === 'month')!.value;
  const day = parts.find(p => p.type === 'day')!.value;
  const localDateStr = `${year}-${month}-${day}`;

  dateByEvent[e.id] = localDateStr;
  datesSet.add(localDateStr);
});
const dates = [...datesSet].sort();

// Build matrix data
const recordsByMember: Record<string, { date: string; status: AttendanceStatus; reason: string | null }[]> = {};
attendance.forEach(a => {
  if (!a.roster_member_id) return;
  const date = dateByEvent[a.event_id];
  if (!date) return;
  const status = (a.status === 'on_time' ? 'present' : a.status) as AttendanceStatus;
  if (!recordsByMember[a.roster_member_id]) recordsByMember[a.roster_member_id] = [];
  recordsByMember[a.roster_member_id].push({ date, status, reason: a.note ?? null });
});

const data: AttendanceData = {
  dates,
  attendees: roster.map(m => ({
    id: m.id,
    name: m.full_name,
    records: recordsByMember[m.id] || [],
  })),
};

// Stats
type AttendeeStat = {
  id: string;
  name: string;
  present: number;
  late: number;
  absent: number;
  total: number;
  attendanceRate: number;
};
const stats: AttendeeStat[] = data.attendees.map(a => {
  const present = a.records.filter(r => r.status === 'present').length;
  const late = a.records.filter(r => r.status === 'late').length;
  const absent = a.records.filter(r => r.status === 'absent').length;
  const total = a.records.length;
  const attendanceRate = total > 0 ? Math.round(((present + late) / total) * 100) : 0;
  return { id: a.id, name: a.name, present, late, absent, total, attendanceRate };
});

const totalPresent = stats.reduce((s, a) => s + a.present, 0);
const totalLate = stats.reduce((s, a) => s + a.late, 0);
const totalAbsent = stats.reduce((s, a) => s + a.absent, 0);
const totalRecords = totalPresent + totalLate + totalAbsent;
const onTimeRate = totalRecords > 0 ? Math.round((totalPresent / totalRecords) * 100) : 0;

const topAttendees = [...stats].sort((a, b) => (b.present + b.late) - (a.present + a.late)).slice(0, 8);
const leastAttendees = [...stats]
  .filter(s => s.total > 0)
  .sort((a, b) => (a.present + a.late) - (b.present + b.late))
  .slice(0, 5);
const mostLate = [...stats].filter(s => s.late > 0).sort((a, b) => b.late - a.late).slice(0, 5);

const perEventStats = dates.map(d => {
  let p = 0, l = 0, ab = 0;
  data.attendees.forEach(a => {
    const rec = a.records.find(r => r.date === d);
    if (rec) {
      if (rec.status === 'present') p++;
      else if (rec.status === 'late') l++;
      else if (rec.status === 'absent') ab++;
    }
  });
  return { date: d, present: p, late: l, absent: ab, total: p + l + ab };
});

const hasData = roster.length > 0 && events.length > 0;
---
<Layout title="Dashboard">
  <main class="max-w-7xl mx-auto p-6 md:p-8">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
      <div>
        <p class="text-sm text-muted-foreground">Welcome back,</p>
        <h1 class="text-3xl font-semibold tracking-tight mt-0.5">{displayName}</h1>
      </div>
      {isAdmin && (
        <div class="flex items-center gap-2">
          <a href="/admin/roster">
            <AstroButton variant="outline" size="sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              Roster
            </AstroButton>
          </a>
          <a href="/admin">
            <AstroButton variant="outline" size="sm">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-12a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2"></path></svg>
              Manage events
            </AstroButton>
          </a>
        </div>
      )}
    </div>

    {!hasData ? (
      <AstroCard className="p-12 text-center">
        <div class="inline-flex p-3 rounded-full bg-muted mb-4">
          <svg class="w-6 h-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
        </div>
        <p class="text-base font-medium">No attendance data yet</p>
        <p class="text-sm text-muted-foreground mt-1">{isAdmin ? 'Create your first event or seed the roster to get started.' : 'Once events are recorded you\'ll see analytics here.'}</p>
      </AstroCard>
    ) : (
      <>
        <!-- Top stats banner (no individual cards) -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 py-6 border-y border-border mb-8 bg-card/10 px-6 rounded-xl">
          <div class="flex flex-col gap-1 first:pl-0 md:border-r border-border md:pr-6 last:border-r-0">
            <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Events</span>
            <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{dates.length}</span>
          </div>
          <div class="flex flex-col gap-1 md:border-r border-border md:px-6 last:border-r-0">
            <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Roster</span>
            <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{roster.length}</span>
          </div>
          <div class="flex flex-col gap-1 md:border-r border-border md:px-6 last:border-r-0">
            <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">On-time rate</span>
            <div class="flex items-baseline gap-1.5">
              <span class="text-3xl font-bold tracking-tight text-foreground tabular-nums">{onTimeRate}%</span>
            </div>
            <div class="mt-2 h-1.5 w-full bg-muted rounded-full overflow-hidden">
              <div class="h-full bg-emerald-400 rounded-full" style={`width:${onTimeRate}%`}></div>
            </div>
          </div>
          <div class="flex flex-col gap-1 md:pl-6">
            <span class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Late / Absent</span>
            <div class="flex items-baseline gap-1 text-3xl font-bold tracking-tight text-foreground tabular-nums">
              <span>{totalLate}</span>
              <span class="text-xl font-normal text-muted-foreground">/</span>
              <span class="text-muted-foreground">{totalAbsent}</span>
            </div>
          </div>
        </div>

        <!-- Attendance Matrix -->
        <AstroCard className="p-6 mb-8 overflow-hidden">
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-5">
            <div>
              <h2 class="text-lg font-semibold tracking-tight">Attendance matrix</h2>
              <p class="text-xs text-muted-foreground mt-0.5">{isAdmin ? 'Hover for details, click any cell to add or edit a note.' : 'Hover any cell for status and notes.'}</p>
            </div>
            <div class="flex items-center gap-3 text-xs flex-wrap">
              <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-emerald-300"></span>Present</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-amber-300"></span>Late</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-rose-300"></span>Absent</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-muted"></span>N/A</span>
              <span class="inline-flex items-center gap-1.5"><span class="h-1.5 w-1.5 rounded-full bg-foreground/40"></span>Has note</span>
            </div>
          </div>

          <AttendanceMatrix data={data} canEditNotes={isAdmin} noteApiUrl={isAdmin ? "/api/attendance/note" : undefined} client:load />
        </AstroCard>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
          <AstroCard className="p-6">
            <div class="flex items-center justify-between mb-5">
              <div>
                <h2 class="text-lg font-semibold tracking-tight">Top attendees</h2>
                <p class="text-xs text-muted-foreground mt-0.5">Stacked: present / late / absent</p>
              </div>
              <AstroBadge variant="secondary">{roster.length} total</AstroBadge>
            </div>
            <TopAttendeesChart data={topAttendees.map(a => ({ name: a.name, present: a.present, late: a.late, absent: a.absent }))} client:load />
          </AstroCard>

          <AstroCard className="p-6">
            <div class="mb-5">
              <h2 class="text-lg font-semibold tracking-tight">Attendance per event</h2>
              <p class="text-xs text-muted-foreground mt-0.5">Stacked: present / late / absent</p>
            </div>
            <PerEventStackedBars data={perEventStats} client:load />
          </AstroCard>
        </div>

        <!-- Roster Insights Panel -->
        <AstroCard className="p-6 mb-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 divide-y md:divide-y-0 md:divide-x divide-border">
            <div>
              <div class="mb-5">
                <h2 class="text-lg font-semibold tracking-tight">Least active</h2>
                <p class="text-xs text-muted-foreground mt-0.5">Lowest attendance count</p>
              </div>
              <ul class="space-y-2">
                {leastAttendees.map(a => (
                  <li class="flex items-center justify-between gap-3 p-3 rounded-2xl bg-muted/40 hover-row-premium">
                    <div class="min-w-0">
                      <p class="text-sm font-medium truncate">{a.name}</p>
                      <p class="text-xs text-muted-foreground">{a.absent} missed · {a.attendanceRate}% rate</p>
                    </div>
                    <AstroBadge variant="outline">{a.present + a.late}/{a.total}</AstroBadge>
                  </li>
                ))}
              </ul>
            </div>

            <div class="pt-6 md:pt-0 md:pl-8">
              <div class="mb-5">
                <h2 class="text-lg font-semibold tracking-tight">Most late arrivals</h2>
                <p class="text-xs text-muted-foreground mt-0.5">Total late check-ins</p>
              </div>
              {mostLate.length === 0 ? (
                <p class="text-sm text-muted-foreground py-8 text-center">No late check-ins recorded.</p>
              ) : (
                <ul class="space-y-2">
                  {mostLate.map(a => (
                    <li class="flex items-center justify-between gap-3 p-3 rounded-2xl bg-muted/40 hover-row-premium">
                      <div class="min-w-0">
                        <p class="text-sm font-medium truncate">{a.name}</p>
                        <p class="text-xs text-muted-foreground">{a.present} present · {a.absent} absent</p>
                      </div>
                      <AstroBadge variant="warning">{a.late} late</AstroBadge>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        </AstroCard>v>
      </>
    )}
  </main>

</Layout>
