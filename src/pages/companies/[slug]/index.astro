---
import Layout from '../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../lib/supabase';
import AstroCard from '../../../components/AstroCard.astro';
import AstroButton from '../../../components/AstroButton.astro';
import AstroBadge from '../../../components/AstroBadge.astro';
import { Input } from '../../../components/ui/input';
import { Label } from '../../../components/ui/label';
import { ArrowLeft, Users, Plus, Shield, Link } from 'lucide-react';

const { slug } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: company } = await supabase
  .from('companies')
  .select('*')
  .eq('slug', slug)
  .single();

if (!company) return Astro.redirect('/companies');

let errorMsg = '';

const [memberInfoRes, profileRes] = await Promise.all([
  supabase
    .from('company_members')
    .select('role')
    .eq('company_id', company.id)
    .eq('user_id', session.user.id)
    .maybeSingle(),
  supabase
    .from('profiles')
    .select('role')
    .eq('id', session.user.id)
    .single()
]);

const isCompanyMember = !!memberInfoRes.data;
const isCompanyAdmin = memberInfoRes.data?.role === 'admin';
const isGlobalAdmin = profileRes.data?.role === 'admin';
const isAdmin = isGlobalAdmin || isCompanyAdmin;

if (!isAdmin) {
  return Astro.redirect('/dashboard');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');

  if (action === 'create_team') {
    if (!isAdmin) {
      errorMsg = 'Unauthorized';
    } else {
      const name = (formData.get('team_name') || '').toString().trim();
      if (!name) {
        errorMsg = 'Team name is required';
      } else {
        const invite_code = crypto.randomUUID();
        const { error } = await supabase
          .from('teams')
          .insert({ company_id: company.id, name, invite_code, created_by: session.user.id });
        if (!error) {
          return Astro.redirect(`/companies/${slug}`);
        } else {
          errorMsg = error.message;
        }
      }
    }
  }
}

const [teamsRes, membersRes] = await Promise.all([
  supabase.from('teams').select('*').eq('company_id', company.id).order('name'),
  supabase.from('company_members').select('role, user_id, profiles(full_name, email)').eq('company_id', company.id)
]);

const teams = teamsRes.data || [];
const members = membersRes.data || [];
---

<Layout title={`${company.name} - Details`}>
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <a href="/companies" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <ArrowLeft className="w-4 h-4" />
      Back to companies
    </a>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">{company.name}</h1>
        <p class="text-muted-foreground mt-1 text-sm">Manage teams and view roster membership within the company.</p>
      </div>
      <div>
        <AstroBadge variant="default">
          Company Admin
        </AstroBadge>
      </div>
    </div>

    {errorMsg && (
      <div class="p-4 mb-6 text-sm text-red-500 bg-red-50 rounded-2xl border border-red-200">
        {errorMsg}
      </div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Teams Column -->
      <div class={isAdmin ? "lg:col-span-2 space-y-6" : "lg:col-span-3 space-y-6"}>
        <div class="flex items-center justify-between">
          <h2 class="text-xl font-semibold tracking-tight">Teams</h2>
          {isAdmin && (
            <AstroButton size="sm" id="show-create-team-btn" onclick="document.getElementById('create-team-card').classList.remove('hidden')">
              <Plus className="w-4 h-4 mr-1" /> Create Team
            </AstroButton>
          )}
        </div>

        <!-- Create Team Card (Hidden by default) -->
        <div id="create-team-card" class="hidden">
          <AstroCard className="p-5 border-primary/30">
            <h3 class="text-base font-semibold mb-3">New Team</h3>
            <form method="post" class="space-y-4">
              <input type="hidden" name="_action" value="create_team" />
              <div class="space-y-1.5">
                <Label htmlFor="team_name">Team Name</Label>
                <Input id="team_name" name="team_name" required placeholder="e.g. engineering, design, marketing" />
              </div>
              <div class="flex gap-2 justify-end">
                <AstroButton type="button" variant="outline" size="sm" onclick="document.getElementById('create-team-card').classList.add('hidden')">
                  Cancel
                </AstroButton>
                <AstroButton type="submit" size="sm">
                  Create Team
                </AstroButton>
              </div>
            </form>
          </AstroCard>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {teams.map(t => (
            <AstroCard className="p-5 flex flex-col justify-between hover:shadow-md transition-all duration-200">
              <div>
                <h3 class="font-semibold text-base text-foreground">{t.name}</h3>
                {isAdmin && (
                  <div class="mt-3 space-y-1 text-xs text-muted-foreground bg-muted/40 p-2.5 rounded-xl border">
                    <div class="flex items-center gap-1 font-medium">
                      <Link className="w-3.5 h-3.5" /> Invite Link
                    </div>
                    <code class="block font-mono break-all mt-1 bg-background p-1 border rounded text-[10px]">
                      {Astro.url.origin}/teams/join/{t.invite_code}
                    </code>
                  </div>
                )}
              </div>
              <div class="flex gap-2 mt-4 pt-4 border-t border-border/50 justify-between items-center">
                <a href={`/admin?team_id=${t.id}`} class="text-xs text-primary font-medium hover:underline">
                  Manage Events &rarr;
                </a>
                <a href={`/admin/roster?team_id=${t.id}`} class="text-xs text-primary font-medium hover:underline">
                  Manage Roster &rarr;
                </a>
              </div>
            </AstroCard>
          ))}
          {teams.length === 0 && (
            <div class="col-span-full p-12 text-center text-muted-foreground text-sm border rounded-2xl bg-card">
              No teams in this company yet.
            </div>
          )}
        </div>
      </div>

      <!-- Members Column -->
      {isAdmin && (
        <div class="lg:col-span-1 space-y-4">
          <h2 class="text-xl font-semibold tracking-tight">Company Members</h2>
          <AstroCard className="p-4">
            <div class="divide-y divide-border">
              {members.map(m => {
                const p = (m.profiles as any) || {};
                const name = p.full_name || 'Anonymous Member';
                const email = p.email || 'No email';
                return (
                  <div class="py-3 flex items-center justify-between gap-2 first:pt-0 last:pb-0">
                    <div class="min-w-0">
                      <p class="text-sm font-semibold truncate text-foreground">{name}</p>
                      <p class="text-xs text-muted-foreground truncate">{email}</p>
                    </div>
                    <AstroBadge variant={m.role === 'admin' ? 'default' : 'secondary'} className="shrink-0">
                      {m.role}
                    </AstroBadge>
                  </div>
                );
              })}
            </div>
          </AstroCard>
        </div>
      )}
    </div>
  </main>
</Layout>
