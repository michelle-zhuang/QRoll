---
import Layout from '../layouts/Layout.astro';
import AstroButton from '../components/AstroButton.astro';
---

<Layout title="404 - Page Not Found" hideNavbar={true}>
  <main class="min-h-screen flex flex-col items-center justify-center p-6 relative overflow-hidden text-center gap-6">
    <!-- Floating background glow blobs -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[450px] h-[450px] bg-[#A9DEF9] opacity-40 rounded-full blur-[120px] pointer-events-none animate-blob-1"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[450px] h-[450px] bg-[#E4C1F9] opacity-40 rounded-full blur-[120px] pointer-events-none animate-blob-2"></div>
    
    <div class="w-full max-w-[280px] md:max-w-[320px] max-h-[32vh] aspect-square flex items-center justify-center overflow-hidden animate-slide-down relative z-10">
      <img src="/404.svg" alt="404 Illustration" class="w-full max-h-full object-contain select-none pointer-events-none" />
    </div>

    <div class="space-y-3 relative z-10">
      <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-foreground">Lost in the Rhythm</h1>
      <p class="text-muted-foreground text-sm md:text-base max-w-xs mx-auto">
        We're still imagining this page.
      </p>
    </div>

    <div class="relative z-10 pt-2">
      <a href="/dashboard">
        <AstroButton className="h-11 px-8">
          Back to Dashboard
        </AstroButton>
      </a>
    </div>
  </main>
</Layout>
