---
import Layout from '../layouts/Layout.astro';
import AstroButton from '../components/AstroButton.astro';
import AstroCard from '../components/AstroCard.astro';
---

<Layout title="404 - Page Not Found">
  <main class="min-h-[calc(100vh-3.5rem)] flex items-center justify-center p-6 relative overflow-hidden">
    <!-- Floating background glow blobs -->
    <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-[#A9DEF9] opacity-40 rounded-full blur-[100px] pointer-events-none animate-blob-1"></div>
    <div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[350px] h-[350px] bg-[#E4C1F9] opacity-40 rounded-full blur-[100px] pointer-events-none animate-blob-2"></div>
    
    <AstroCard className="w-full max-w-lg relative z-10 p-8 md:p-12 text-center flex flex-col items-center gap-6">
      <div class="w-full max-w-[280px] md:max-w-[320px] aspect-square flex items-center justify-center overflow-hidden animate-slide-down">
        <img src="/404.svg" alt="404 Illustration" class="w-full h-auto object-contain select-none pointer-events-none" />
      </div>

      <div class="space-y-3">
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Lost in the Rhythm</h1>
        <p class="text-muted-foreground text-sm max-w-xs mx-auto">
          We're still imagining this page.
        </p>
      </div>

      <a href="/dashboard" class="w-full sm:w-auto pt-2">
        <AstroButton className="w-full sm:w-auto h-11 px-8">
          Back to Dashboard
        </AstroButton>
      </a>
    </AstroCard>
  </main>
</Layout>
