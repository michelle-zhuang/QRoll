---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseClient } from '../../lib/supabase';
import AstroButton from '../../components/AstroButton.astro';
import { EventsTable } from '../../components/EventsTable';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role, full_name, email').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const allowMemberDashboard = formData.get('allow_member_dashboard') === 'true';

  await supabase.from('app_settings').upsert({
    key: 'allow_member_dashboard',
    value: allowMemberDashboard
  });
}

const { data: setting } = await supabase
  .from('app_settings')
  .select('value')
  .eq('key', 'allow_member_dashboard')
  .maybeSingle();
const allowMemberDashboard = setting ? (setting.value === true || setting.value === 'true') : false;

const { data: events } = await supabase.from('events').select('*').order('created_at', { ascending: false });
---
<Layout title="Admin Dashboard">
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-balance">Events</h1>
        <p class="text-muted-foreground mt-2 text-sm">Manage your events and track real-time attendance.</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/roster">
          <AstroButton variant="outline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            Roster
          </AstroButton>
        </a>
        <a href="/admin/events/new">
          <AstroButton>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Create event
          </AstroButton>
        </a>
      </div>
    </div>

    <!-- Global App Settings Section -->
    <div class="bg-card border border-border rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="space-y-1">
        <h2 class="text-lg font-semibold tracking-tight">Member Dashboard Access</h2>
        <p class="text-xs text-muted-foreground">Control whether regular members can access the attendance dashboard page.</p>
      </div>
      <form method="POST" id="setting-form">
        <input type="hidden" name="allow_member_dashboard" value={allowMemberDashboard ? "false" : "true"} />
        <AstroButton type="submit" variant={allowMemberDashboard ? "destructive" : "default"} className="h-10 px-4 rounded-xl text-xs font-semibold">
          {allowMemberDashboard ? "Restrict Member Dashboard" : "Allow Member Dashboard"}
        </AstroButton>
      </form>
    </div>

    <EventsTable events={events || []} client:load />
  </main>
</Layout>
