---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseClient } from '../../lib/supabase';
import AstroButton from '../../components/AstroButton.astro';
import { EventsTable } from '../../components/EventsTable';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const [profileRes, settingRes, myCompanyMembershipsRes] = await Promise.all([
  supabase.from('profiles').select('role, full_name, email').eq('id', session.user.id).single(),
  supabase.from('app_settings').select('value').eq('key', 'allow_member_dashboard').maybeSingle(),
  supabase.from('company_members').select('company_id, role').eq('user_id', session.user.id)
]);

const profile = profileRes.data;
const isGlobalAdmin = profile?.role === 'admin';
const adminCompanyIds = (myCompanyMembershipsRes.data || [])
  .filter(cm => cm.role === 'admin')
  .map(cm => cm.company_id);

if (!isGlobalAdmin && adminCompanyIds.length === 0) {
  return Astro.redirect('/dashboard');
}

let manageableCompanies = [];
let manageableTeams = [];

if (isGlobalAdmin) {
  const [companiesRes, teamsRes] = await Promise.all([
    supabase.from('companies').select('*').order('name'),
    supabase.from('teams').select('*').order('name')
  ]);
  manageableCompanies = companiesRes.data || [];
  manageableTeams = teamsRes.data || [];
} else {
  const [companiesRes, teamsRes] = await Promise.all([
    supabase.from('companies').select('*').in('id', adminCompanyIds).order('name'),
    supabase.from('teams').select('*').in('company_id', adminCompanyIds).order('name')
  ]);
  manageableCompanies = companiesRes.data || [];
  manageableTeams = teamsRes.data || [];
}

const url = new URL(Astro.request.url);
let teamId = url.searchParams.get('team_id') || Astro.cookies.get('active_team_id')?.value;

if (url.searchParams.get('team_id')) {
  Astro.cookies.set('active_team_id', url.searchParams.get('team_id')!, { path: '/' });
  teamId = url.searchParams.get('team_id')!;
}

let currentTeam = manageableTeams.find(t => t.id === teamId);
if (!currentTeam && manageableTeams.length > 0) {
  currentTeam = manageableTeams[0];
  teamId = currentTeam.id;
  Astro.cookies.set('active_team_id', currentTeam.id, { path: '/' });
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const allowMemberDashboard = formData.get('allow_member_dashboard') === 'true';

  await supabase.from('app_settings').upsert({
    key: 'allow_member_dashboard',
    value: allowMemberDashboard
  });
  return Astro.redirect('/admin');
}

const setting = settingRes?.data;
const allowMemberDashboard = setting ? (setting.value === true || setting.value === 'true') : false;

const eventsRes = teamId
  ? await supabase.from('events').select('*').eq('team_id', teamId).order('created_at', { ascending: false })
  : { data: [] };
const events = eventsRes.data || [];

const teamsWithCompany = manageableTeams.map(team => {
  const company = manageableCompanies.find(c => c.id === team.company_id);
  return {
    ...team,
    companyName: company ? company.name : 'Unknown Company'
  };
});
---
<Layout title="Admin Dashboard">
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-balance">Events</h1>
        <p class="text-muted-foreground mt-2 text-sm">Manage your events and track real-time attendance.</p>
      </div>
      <div class="flex gap-2">
        <a href="/admin/roster">
          <AstroButton variant="outline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87M16 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            Roster
          </AstroButton>
        </a>
        <a href="/admin/events/new">
          <AstroButton>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Create event
          </AstroButton>
        </a>
      </div>
    </div>

    <!-- Team Selector -->
    {manageableTeams.length > 0 && (
      <div class="bg-card border border-border rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
        <div class="space-y-1">
          <h2 class="text-lg font-semibold tracking-tight">Active Team</h2>
          <p class="text-xs text-muted-foreground">Manage events and attendance for a specific team.</p>
        </div>
        <form method="get" class="flex items-center gap-2">
          <select
            id="team-selector"
            name="team_id"
            onchange="this.form.submit()"
            class="flex h-10 rounded-2xl border border-input bg-background px-3 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
          >
            {teamsWithCompany.map(t => (
              <option value={t.id} selected={t.id === teamId}>
                {t.companyName} - {t.name}
              </option>
            ))}
          </select>
        </form>
      </div>
    )}

    <!-- Global App Settings Section -->
    <div class="bg-card border border-border rounded-2xl p-6 mb-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="space-y-1">
        <h2 class="text-lg font-semibold tracking-tight">Member Dashboard Access</h2>
        <p class="text-xs text-muted-foreground">Control whether regular members can access the attendance dashboard page.</p>
      </div>
      <form method="POST" id="setting-form">
        <input type="hidden" name="allow_member_dashboard" value={allowMemberDashboard ? "false" : "true"} />
        <AstroButton type="submit" variant={allowMemberDashboard ? "destructive" : "default"} className="h-10 px-4 rounded-xl text-xs font-semibold">
          {allowMemberDashboard ? "Restrict Member Dashboard" : "Allow Member Dashboard"}
        </AstroButton>
      </form>
    </div>

    <EventsTable events={events || []} client:load />
  </main>
</Layout>
