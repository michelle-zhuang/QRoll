---
import Layout from '../../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../../lib/supabase';
import AstroCard from '../../../../components/AstroCard.astro';
import AstroButton from '../../../../components/AstroButton.astro';
import { Input } from '../../../../components/ui/input';
import { Label } from '../../../../components/ui/label';
import { Textarea } from '../../../../components/ui/textarea';
import { DateTimePicker } from '../../../../components/DateTimePicker';
import { toZonedTime } from 'date-fns-tz';
import { PACIFIC_TIMEZONE } from '../../../../lib/timeLogic';

const { id } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const [profileRes, eventRes] = await Promise.all([
  supabase.from('profiles').select('role').eq('id', session.user.id).single(),
  supabase.from('events').select('*').eq('id', id).single()
]);

const profile = profileRes.data;
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title');
  const description = formData.get('description');
  const starts_at = formData.get('starts_at');
  const checkin_opens_at = formData.get('checkin_opens_at');
  const late_after_at = formData.get('late_after_at');
  const checkin_closes_at = formData.get('checkin_closes_at');

  const geofenceEnabled = formData.get('geofence_enabled') === 'true';
  const latitude = formData.get('latitude') ? parseFloat(formData.get('latitude') as string) : null;
  const longitude = formData.get('longitude') ? parseFloat(formData.get('longitude') as string) : null;
  const radius = formData.get('geofence_radius_meters') ? parseInt(formData.get('geofence_radius_meters') as string, 10) : 100;

  const { error } = await supabase.from('events').update({
    title, description, starts_at, checkin_opens_at, late_after_at, checkin_closes_at,
    geofence_enabled: geofenceEnabled,
    latitude: geofenceEnabled ? latitude : null,
    longitude: geofenceEnabled ? longitude : null,
    geofence_radius_meters: geofenceEnabled ? radius : 100,
  }).eq('id', id);

  if (!error) return Astro.redirect(`/admin/events/${id}?toast=` + encodeURIComponent('Event updated') + '&toastType=success');
  errorMsg = error.message;
}

const event = eventRes.data;
if (!event) return Astro.redirect('/admin');

const formatDateTime = (dateString: string | null) => {
  if (!dateString) return '';
  const dateInPacific = toZonedTime(new Date(dateString), PACIFIC_TIMEZONE);
  const year = dateInPacific.getFullYear();
  const month = String(dateInPacific.getMonth() + 1).padStart(2, "0");
  const day = String(dateInPacific.getDate()).padStart(2, "0");
  const hour = String(dateInPacific.getHours()).padStart(2, "0");
  const minute = String(dateInPacific.getMinutes()).padStart(2, "0");
  return `${year}-${month}-${day}T${hour}:${minute}`;
};

const startsAt = formatDateTime(event.starts_at);
const opensAt = formatDateTime(event.checkin_opens_at);
const lateAt = formatDateTime(event.late_after_at);
const closesAt = formatDateTime(event.checkin_closes_at);
---
<Layout title="Edit Event">
  <main class="max-w-2xl mx-auto p-6 md:p-8">
    <a href={`/admin/events/${id}`} class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to event
    </a>

    <AstroCard className="p-6 md:p-8">
      <div class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight">Edit event</h1>
        <p class="text-muted-foreground mt-1 text-sm">Update the schedule and details for your event check-in.</p>
      </div>

      {errorMsg && (
        <div class="bg-destructive/10 border border-destructive/30 text-destructive text-sm p-3 rounded-2xl mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <span>{errorMsg}</span>
        </div>
      )}

      <form method="post" class="space-y-6">
        <div class="space-y-2">
          <Label htmlFor="title">Event title</Label>
          <Input id="title" name="title" type="text" required value={event.title} placeholder="Annual General Meeting 2026" />
        </div>

        <div class="space-y-2">
          <Label htmlFor="description">Description (optional)</Label>
          <Textarea id="description" name="description" placeholder="Provide context or instructions for attendees..." className="min-h-[100px] resize-none" defaultValue={event.description || ''} />
        </div>

        <div class="grid grid-cols-1 gap-4 pt-4 border-t">
          <div class="space-y-2">
            <Label>Event starts at</Label>
            <DateTimePicker name="starts_at" defaultValue={startsAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Check-in opens</Label>
            <DateTimePicker name="checkin_opens_at" defaultValue={opensAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Mark late after</Label>
            <DateTimePicker name="late_after_at" defaultValue={lateAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Check-in closes</Label>
            <DateTimePicker name="checkin_closes_at" defaultValue={closesAt} required client:load />
          </div>
        </div>

        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

        <div class="space-y-4 pt-6 border-t">
          <div class="flex items-center justify-between">
            <div class="space-y-0.5">
              <Label htmlFor="geofence_toggle" className="text-base font-semibold">Geofencing Verification</Label>
              <p class="text-xs text-muted-foreground">Restrict check-ins to a physical radius around the event venue.</p>
            </div>
            <button
              type="button"
              id="geofence-toggle"
              role="switch"
              aria-checked={event.geofence_enabled ? 'true' : 'false'}
              class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-muted-foreground/30"
            >
              <span class="sr-only">Enable geofencing</span>
              <span id="geofence-toggle-handle" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-background shadow ring-0 transition duration-200 ease-in-out translate-x-0"></span>
            </button>
            <input type="hidden" name="geofence_enabled" id="geofence_enabled_val" value={event.geofence_enabled ? 'true' : 'false'} />
          </div>

          <div id="geofence-panel" class="hidden space-y-4 mt-4 transition-all duration-200">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pb-2 border-b">
              <div class="space-y-2 col-span-1 sm:col-span-2">
                <Label htmlFor="geo_search">Search Location / Address</Label>
                <div class="flex gap-2">
                  <Input id="geo_search" name="geo_search" type="text" placeholder="e.g. Space Needle, Seattle" className="flex-1" />
                  <AstroButton type="button" id="btn-search-address" className="h-10 px-4 rounded-xl text-xs font-semibold">
                    Search
                  </AstroButton>
                </div>
                <span id="search-status" class="text-xs text-muted-foreground block min-h-[1rem]"></span>
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="space-y-2">
                <Label htmlFor="latitude">Latitude</Label>
                <Input id="latitude" name="latitude" type="number" step="any" placeholder="e.g. 47.5492" className="bg-background" value={event.latitude || ''} />
              </div>
              <div class="space-y-2">
                <Label htmlFor="longitude">Longitude</Label>
                <Input id="longitude" name="longitude" type="number" step="any" placeholder="e.g. -122.3218" className="bg-background" value={event.longitude || ''} />
              </div>
              <div class="space-y-2">
                <Label htmlFor="geofence_radius_meters">Radius (meters)</Label>
                <Input id="geofence_radius_meters" name="geofence_radius_meters" type="number" min="10" max="5000" defaultValue={event.geofence_radius_meters || 100} />
              </div>
            </div>

            <div class="flex items-center gap-2">
              <AstroButton type="button" id="btn-use-current" variant="outline" size="sm" className="h-9 text-xs rounded-full">
                Pin to my current location
              </AstroButton>
              <span id="geo-status" class="text-xs text-muted-foreground"></span>
            </div>

            <div class="relative w-full h-[300px] rounded-2xl overflow-hidden border border-border" id="map-container">
              <div id="geofence-map" class="w-full h-full bg-muted/40 z-0"></div>
            </div>
            <p class="text-xs text-muted-foreground italic">Click anywhere on the map or type coordinates/address above to change the geofence center.</p>
          </div>
        </div>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('geofence-toggle');
            const handle = document.getElementById('geofence-toggle-handle');
            const hiddenVal = document.getElementById('geofence_enabled_val');
            const panel = document.getElementById('geofence-panel');

            const latInput = document.getElementById('latitude');
            const lonInput = document.getElementById('longitude');
            const radiusInput = document.getElementById('geofence_radius_meters');

            const useCurrentBtn = document.getElementById('btn-use-current');
            const geoStatus = document.getElementById('geo-status');

            const searchInput = document.getElementById('geo_search');
            const searchBtn = document.getElementById('btn-search-address');
            const searchStatus = document.getElementById('search-status');

            let map = null;
            let marker = null;
            let circle = null;

            // Default coordinates: default to 47.5492 and -122.3218
            let defaultLat = 47.5492;
            let defaultLon = -122.3218;
            let defaultRadius = parseInt(radiusInput.value, 10) || 100;

            function setToggleState(enabled) {
              if (enabled) {
                toggle.setAttribute('aria-checked', 'true');
                toggle.classList.remove('bg-muted-foreground/30');
                toggle.classList.add('bg-primary');
                handle.classList.remove('translate-x-0');
                handle.classList.add('translate-x-5');
                hiddenVal.value = 'true';
                panel.classList.remove('hidden');

                // Initialize Leaflet Map if not already initialized
                setTimeout(initMap, 50);
              } else {
                toggle.setAttribute('aria-checked', 'false');
                toggle.classList.remove('bg-primary');
                toggle.classList.add('bg-muted-foreground/30');
                handle.classList.remove('translate-x-5');
                handle.classList.add('translate-x-0');
                hiddenVal.value = 'false';
                panel.classList.add('hidden');
              }
            }

            toggle.addEventListener('click', () => {
              const enabled = toggle.getAttribute('aria-checked') === 'false';
              setToggleState(enabled);
            });

            function updateInputs(lat, lon) {
              latInput.value = lat.toFixed(6);
              lonInput.value = lon.toFixed(6);
            }

            function initMap() {
              if (map) {
                map.invalidateSize();
                return;
              }

              // Check if coordinates were empty
              if (!latInput.value || !lonInput.value) {
                updateInputs(defaultLat, defaultLon);
              } else {
                defaultLat = parseFloat(latInput.value);
                defaultLon = parseFloat(lonInput.value);
              }

              map = L.map('geofence-map').setView([defaultLat, defaultLon], 15);

              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
              }).addTo(map);

              // Use custom divIcon to avoid asset-loading issues in frameworks
              const customIcon = L.divIcon({
                className: 'custom-div-icon',
                html: `<div class="w-6 h-6 rounded-full bg-[#2F2738] border-2 border-white shadow flex items-center justify-center"><div class="w-2.5 h-2.5 rounded-full bg-[#E4C1F9] animate-pulse"></div></div>`,
                iconSize: [24, 24],
                iconAnchor: [12, 12]
              });

              // Add marker
              marker = L.marker([defaultLat, defaultLon], { draggable: true, icon: customIcon }).addTo(map);

              // Add circle radius
              circle = L.circle([defaultLat, defaultLon], {
                color: '#E4C1F9',
                fillColor: '#E4C1F9',
                fillOpacity: 0.35,
                radius: defaultRadius
              }).addTo(map);

              // Marker drag event
              marker.on('drag', (e) => {
                const position = marker.getLatLng();
                updateInputs(position.lat, position.lng);
                circle.setLatLng(position);
              });

              // Map click event
              map.on('click', (e) => {
                const position = e.latlng;
                marker.setLatLng(position);
                circle.setLatLng(position);
                updateInputs(position.lat, position.lng);
              });

              // Radius change event
              radiusInput.addEventListener('input', () => {
                const r = parseInt(radiusInput.value, 10) || 100;
                circle.setRadius(r);
              });
            }

            // Reposition map and marker when lat/lon inputs are typed manually
            function handleCoordinateInput() {
              const lat = parseFloat(latInput.value);
              const lon = parseFloat(lonInput.value);
              if (!isNaN(lat) && !isNaN(lon) && lat >= -90 && lat <= 90 && lon >= -180 && lon <= 180) {
                if (map && marker && circle) {
                  marker.setLatLng([lat, lon]);
                  circle.setLatLng([lat, lon]);
                  map.setView([lat, lon], map.getZoom());
                }
              }
            }

            latInput.addEventListener('input', handleCoordinateInput);
            lonInput.addEventListener('input', handleCoordinateInput);

            // Geolocation handler
            useCurrentBtn.addEventListener('click', () => {
              geoStatus.textContent = 'Locating...';
              if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                  (position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;
                    geoStatus.textContent = 'Located!';
                    updateInputs(lat, lon);
                    if (map) {
                      map.setView([lat, lon], 16);
                      marker.setLatLng([lat, lon]);
                      circle.setLatLng([lat, lon]);
                    }
                  },
                  (error) => {
                    geoStatus.textContent = 'Error: ' + error.message;
                  },
                  { enableHighAccuracy: true, timeout: 5000 }
                );
              } else {
                geoStatus.textContent = 'Geolocation not supported';
              }
            });

            // Address Search handler using OSM Nominatim API
            searchBtn.addEventListener('click', async (e) => {
              e.preventDefault();
              const query = searchInput.value.trim();
              if (!query) return;

              searchStatus.textContent = 'Searching...';
              try {
                const response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(query)}`);
                const data = await response.json();
                if (data && data.length > 0) {
                  const lat = parseFloat(data[0].lat);
                  const lon = parseFloat(data[0].lon);
                  searchStatus.textContent = 'Found: ' + data[0].display_name;
                  updateInputs(lat, lon);
                  if (map) {
                    map.setView([lat, lon], 16);
                    marker.setLatLng([lat, lon]);
                    circle.setLatLng([lat, lon]);
                  }
                } else {
                  searchStatus.textContent = 'Location not found';
                }
              } catch (err) {
                searchStatus.textContent = 'Search failed: ' + err.message;
              }
            });

            // Initialize switch state
            const initialEnabled = hiddenVal.value === 'true';
            if (initialEnabled) {
              setToggleState(true);
            }
          });
        </script>

        <div class="flex justify-end gap-2 pt-2">
          <a href={`/admin/events/${id}`}>
            <AstroButton type="button" variant="outline">Cancel</AstroButton>
          </a>
          <AstroButton type="submit">
            Save changes
          </AstroButton>
        </div>
      </form>
    </AstroCard>
  </main>
</Layout>
