---
import Layout from '../../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../../lib/supabase';
import AstroCard from '../../../../components/AstroCard.astro';
import AstroButton from '../../../../components/AstroButton.astro';
import { Input } from '../../../../components/ui/input';
import { Label } from '../../../../components/ui/label';
import { Textarea } from '../../../../components/ui/textarea';

const { id } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title');
  const description = formData.get('description');
  const starts_at = formData.get('starts_at');
  const checkin_opens_at = formData.get('checkin_opens_at');
  const late_after_at = formData.get('late_after_at');
  const checkin_closes_at = formData.get('checkin_closes_at');

  const { error } = await supabase.from('events').update({
    title, description, starts_at, checkin_opens_at, late_after_at, checkin_closes_at
  }).eq('id', id);

  if (!error) return Astro.redirect(`/admin/events/${id}`);
  errorMsg = error.message;
}

const { data: event } = await supabase.from('events').select('*').eq('id', id).single();
if (!event) return Astro.redirect('/admin');

// Format datetime strings for input fields (YYYY-MM-DDThh:mm)
const formatDateTime = (dateString) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  // Handle timezone offsets to keep local time if needed, but simple slice works if the stored time is UTC and we want to show UTC,
  // actually better to pad local time.
  const offset = date.getTimezoneOffset() * 60000;
  const localISOTime = (new Date(date.getTime() - offset)).toISOString().slice(0, 16);
  return localISOTime;
};

const startsAt = formatDateTime(event.starts_at);
const opensAt = formatDateTime(event.checkin_opens_at);
const lateAt = formatDateTime(event.late_after_at);
const closesAt = formatDateTime(event.checkin_closes_at);
---
<Layout title="Edit Event">
  <main class="max-w-3xl mx-auto p-8 my-10">
    <AstroCard className="p-10 shadow-2xl border-primary/10">
      <div class="mb-10">
        <a href={`/admin/events/${id}`} class="text-primary hover:text-primary/80 flex items-center gap-2 mb-6 font-bold transition-all hover:-translate-x-1 w-fit">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Event Details
        </a>
        <h1 class="text-4xl font-extrabold tracking-tight">Edit Event</h1>
        <p class="text-muted-foreground mt-2 text-lg">Update the schedule and details for your event check-in.</p>
      </div>

      {errorMsg && (
        <div class="bg-destructive/10 border-l-4 border-destructive p-4 mb-8 rounded-r-lg">
          <div class="flex items-center gap-3">
             <svg class="w-5 h-5 text-destructive" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
             <p class="text-destructive font-bold text-sm">{errorMsg}</p>
          </div>
        </div>
      )}

      <form method="post" class="space-y-8">
        <div class="space-y-4">
          <div class="space-y-2">
            <Label htmlFor="title" className="text-base font-bold">Event Title</Label>
            <Input id="title" name="title" type="text" required value={event.title} placeholder="Annual General Meeting 2026" className="h-12 text-lg focus-visible:ring-primary/50" />
          </div>
          
          <div class="space-y-2">
            <Label htmlFor="description" className="text-base font-bold">Description (Optional)</Label>
            <Textarea id="description" name="description" placeholder="Provide context or instructions for attendees..." className="min-h-[120px] text-base resize-none focus-visible:ring-primary/50">{event.description}</Textarea>
          </div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 py-6 border-y border-muted/50">
          <div class="space-y-2">
            <Label htmlFor="starts_at" className="text-sm font-bold uppercase tracking-wider text-muted-foreground">Event Starts At</Label>
            <Input id="starts_at" type="datetime-local" name="starts_at" value={startsAt} required className="h-11 focus-visible:ring-primary/50" />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_opens_at" className="text-sm font-bold uppercase tracking-wider text-muted-foreground">Check-in Opens</Label>
            <Input id="checkin_opens_at" type="datetime-local" name="checkin_opens_at" value={opensAt} required className="h-11 focus-visible:ring-primary/50 border-green-200" />
          </div>
          <div class="space-y-2">
            <Label htmlFor="late_after_at" className="text-sm font-bold uppercase tracking-wider text-muted-foreground">Mark Late After</Label>
            <Input id="late_after_at" type="datetime-local" name="late_after_at" value={lateAt} required className="h-11 focus-visible:ring-primary/50 border-orange-200" />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_closes_at" className="text-sm font-bold uppercase tracking-wider text-muted-foreground">Check-in Closes</Label>
            <Input id="checkin_closes_at" type="datetime-local" name="checkin_closes_at" value={closesAt} required className="h-11 focus-visible:ring-primary/50 border-red-200" />
          </div>
        </div>
        
        <AstroButton type="submit" className="w-full h-14 text-xl font-extrabold shadow-xl shadow-primary/20 hover:shadow-primary/40 transition-all hover:-translate-y-0.5 active:translate-y-0">
          Save Changes
        </AstroButton>
      </form>
    </AstroCard>
  </main>
</Layout>
