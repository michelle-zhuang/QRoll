---
import Layout from '../../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../../lib/supabase';
import AstroCard from '../../../../components/AstroCard.astro';
import AstroButton from '../../../../components/AstroButton.astro';
import { Input } from '../../../../components/ui/input';
import { Label } from '../../../../components/ui/label';
import { Textarea } from '../../../../components/ui/textarea';
import { DateTimePicker } from '../../../../components/DateTimePicker';

const { id } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title');
  const description = formData.get('description');
  const starts_at = formData.get('starts_at');
  const checkin_opens_at = formData.get('checkin_opens_at');
  const late_after_at = formData.get('late_after_at');
  const checkin_closes_at = formData.get('checkin_closes_at');

  const { error } = await supabase.from('events').update({
    title, description, starts_at, checkin_opens_at, late_after_at, checkin_closes_at
  }).eq('id', id);

  if (!error) return Astro.redirect(`/admin/events/${id}?toast=` + encodeURIComponent('Event updated') + '&toastType=success');
  errorMsg = error.message;
}

const { data: event } = await supabase.from('events').select('*').eq('id', id).single();
if (!event) return Astro.redirect('/admin');

const formatDateTime = (dateString: string | null) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  const offset = date.getTimezoneOffset() * 60000;
  return (new Date(date.getTime() - offset)).toISOString().slice(0, 16);
};

const startsAt = formatDateTime(event.starts_at);
const opensAt = formatDateTime(event.checkin_opens_at);
const lateAt = formatDateTime(event.late_after_at);
const closesAt = formatDateTime(event.checkin_closes_at);
---
<Layout title="Edit Event">
  <main class="max-w-2xl mx-auto p-6 md:p-8">
    <a href={`/admin/events/${id}`} class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to event
    </a>

    <AstroCard className="p-6 md:p-8">
      <div class="mb-8">
        <h1 class="text-2xl font-semibold tracking-tight">Edit event</h1>
        <p class="text-muted-foreground mt-1 text-sm">Update the schedule and details for your event check-in.</p>
      </div>

      {errorMsg && (
        <div class="bg-destructive/10 border border-destructive/30 text-destructive text-sm p-3 rounded-2xl mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
          <span>{errorMsg}</span>
        </div>
      )}

      <form method="post" class="space-y-6">
        <div class="space-y-2">
          <Label htmlFor="title">Event title</Label>
          <Input id="title" name="title" type="text" required value={event.title} placeholder="Annual General Meeting 2026" />
        </div>

        <div class="space-y-2">
          <Label htmlFor="description">Description (optional)</Label>
          <Textarea id="description" name="description" placeholder="Provide context or instructions for attendees..." className="min-h-[100px] resize-none">{event.description}</Textarea>
        </div>

        <div class="grid grid-cols-1 gap-4 pt-4 border-t">
          <div class="space-y-2">
            <Label>Event starts at</Label>
            <DateTimePicker name="starts_at" defaultValue={startsAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Check-in opens</Label>
            <DateTimePicker name="checkin_opens_at" defaultValue={opensAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Mark late after</Label>
            <DateTimePicker name="late_after_at" defaultValue={lateAt} required client:load />
          </div>
          <div class="space-y-2">
            <Label>Check-in closes</Label>
            <DateTimePicker name="checkin_closes_at" defaultValue={closesAt} required client:load />
          </div>
        </div>

        <div class="flex justify-end gap-2 pt-2">
          <a href={`/admin/events/${id}`}>
            <AstroButton type="button" variant="outline">Cancel</AstroButton>
          </a>
          <AstroButton type="submit">
            Save changes
          </AstroButton>
        </div>
      </form>
    </AstroCard>
  </main>
</Layout>
