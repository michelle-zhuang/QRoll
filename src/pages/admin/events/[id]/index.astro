---
import Layout from '../../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../../lib/supabase';
import QRCode from '../../../../components/QRCode';
import AstroCard from '../../../../components/AstroCard.astro';
import AstroButton from '../../../../components/AstroButton.astro';
import AstroBadge from '../../../../components/AstroBadge.astro';
import { formatPacificTime, formatPacificDateTime } from '../../../../lib/timeLogic';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "../../../../components/ui/table";

const { id } = Astro.params;
const supabase = createSupabaseClient(Astro.cookies);

const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

// Fetch profile + event + company memberships first
const [profileRes, eventRes, myCompanyMembershipsRes] = await Promise.all([
  supabase.from('profiles').select('role').eq('id', session.user.id).single(),
  supabase.from('events').select('*').eq('id', id).single(),
  supabase.from('company_members').select('company_id, role').eq('user_id', session.user.id)
]);

const event = eventRes.data;
if (!event) return Astro.redirect('/admin');

const profile = profileRes.data;
const isGlobalAdmin = profile?.role === 'admin';

// Get company + qr_token of the event team
const { data: teamData } = await supabase.from('teams').select('company_id, qr_token').eq('id', event.team_id).single();
const eventCompanyId = teamData?.company_id;

const isCompanyAdmin = (myCompanyMembershipsRes.data || []).some(
  cm => cm.company_id === eventCompanyId && cm.role === 'admin'
);

if (!isGlobalAdmin && !isCompanyAdmin) {
  return Astro.redirect('/dashboard');
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  if (formData.get('_action') === 'delete') {
    const { error } = await supabase.from('events').delete().eq('id', id);
    if (!error) return Astro.redirect('/admin');
  }
}

// Fetch attendance (joining team_members instead of roster_members) and team roster
const [attendanceRes, rosterRes] = await Promise.all([
  supabase.from('attendance').select('*, profiles(full_name, email), team_members(full_name, email)').eq('event_id', id),
  supabase.from('team_members').select('*').eq('team_id', event.team_id)
]);

const roster = rosterRes.data || [];
const rawAttendance = attendanceRes.data || [];

const isClosed = event.checkin_closes_at && new Date(event.checkin_closes_at) < new Date() && !event.cancelled_at;
const attendedRosterIds = new Set(rawAttendance.map(a => a.team_member_id));

const attendance = [...rawAttendance];
if (isClosed) {
  roster.forEach(m => {
    if (!attendedRosterIds.has(m.id)) {
      attendance.push({
        id: `mock-absent-${m.id}`,
        event_id: id,
        team_member_id: m.id,
        status: 'absent',
        note: null,
        checked_in_at: null,
        team_members: m,
        profiles: null
      } as any);
    }
  });
}

// Sort: present/late first (descending by checked_in_at), then absent
attendance.sort((a, b) => {
  if (a.status === 'absent' && b.status !== 'absent') return 1;
  if (a.status !== 'absent' && b.status === 'absent') return -1;
  if (a.checked_in_at && b.checked_in_at) {
    return new Date(b.checked_in_at).getTime() - new Date(a.checked_in_at).getTime();
  }
  return 0;
});

const lateAfter = event.late_after_at ? new Date(event.late_after_at) : null;
const formatLate = (min: number) => {
  if (min < 1) return '<1m';
  if (min < 60) return `${min}m`;
  const h = Math.floor(min / 60);
  const m = min % 60;
  return m === 0 ? `${h}h` : `${h}h ${m}m`;
};
const lateMinutesFor = (checkedAt: string) => {
  if (!lateAfter) return 0;
  const diff = new Date(checkedAt).getTime() - lateAfter.getTime();
  return Math.max(0, Math.round(diff / 60000));
};

// Team-level QR is the stable default — doesn't change when event is edited.
// Falls back to per-event token for historical events or edge cases.
const checkinUrl = teamData?.qr_token
  ? `${Astro.url.origin}/checkin/${teamData.qr_token}`
  : (event.qr_token ? `${Astro.url.origin}/checkin/${event.qr_token}` : null);
const eventCheckinUrl = event.qr_token ? `${Astro.url.origin}/checkin/${event.qr_token}` : null;
---

<Layout title={`${event.title} - Details`}>
  <main class="max-w-6xl mx-auto p-6 md:p-8">
    <a href="/admin" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to events
    </a>

    <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">{event.title}</h1>
        <p class="text-muted-foreground mt-1 text-sm">Monitoring real-time attendance and event status.</p>
      </div>
      <div class="flex gap-2">
        <a href={`/admin/events/${id}/edit`}>
          <AstroButton variant="outline" size="sm">
            Edit
          </AstroButton>
        </a>
        <form method="post" onsubmit="return confirm('Are you sure you want to delete this event? This action cannot be undone.');">
          <input type="hidden" name="_action" value="delete" />
          <AstroButton type="submit" variant="destructive" size="sm">
            Delete
          </AstroButton>
        </form>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- Event Overview -->
      <AstroCard className="lg:col-span-2 p-6">
        <h2 class="text-base font-semibold mb-6 flex items-center gap-2">
          <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Event overview
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-5 gap-x-8">
          <div class="space-y-1">
            <p class="text-xs font-medium text-muted-foreground">Scheduled for</p>
            <p class="text-sm font-medium">{formatPacificDateTime(event.starts_at)}</p>
          </div>
          <div class="space-y-1">
            <p class="text-xs font-medium text-muted-foreground">Check-in opens</p>
            <p class="text-sm font-medium">{formatPacificTime(event.checkin_opens_at)}</p>
          </div>
          <div class="space-y-1">
            <p class="text-xs font-medium text-muted-foreground">Late threshold</p>
            <p class="text-sm font-medium">{formatPacificTime(event.late_after_at)}</p>
          </div>
          <div class="space-y-1">
            <p class="text-xs font-medium text-muted-foreground">Check-in closes</p>
            <p class="text-sm font-medium">{formatPacificTime(event.checkin_closes_at)}</p>
          </div>
        </div>
        {event.description && (
          <div class="mt-6 pt-6 border-t">
            <p class="text-xs font-medium text-muted-foreground mb-2">Description</p>
            <p class="text-sm text-muted-foreground leading-relaxed">{event.description}</p>
          </div>
        )}
      </AstroCard>

      <!-- QR Code Section -->
      <AstroCard className="p-6 flex flex-col items-center text-center">
        {checkinUrl ? (
          <>
            <h2 class="text-base font-semibold mb-5">Check-in QR code</h2>
            <div class="bg-white p-4 rounded-2xl border mb-5">
              <QRCode value={checkinUrl} client:load />
            </div>
            <div class="w-full space-y-3">
              <div class="space-y-1.5 text-left">
                <p class="text-xs font-medium text-muted-foreground">Check-in URL</p>
                <div class="flex items-center gap-1 bg-muted/40 p-2 rounded-xl border">
                  <code class="text-xs font-mono break-all line-clamp-1 flex-1 text-muted-foreground">
                    {checkinUrl}
                  </code>
                  <AstroButton id="copy-btn" data-url={checkinUrl} size="icon" variant="ghost" className="h-7 w-7" aria-label="Copy check-in URL">
                    <svg id="copy-icon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"></path></svg>
                    <svg id="check-icon" class="w-3.5 h-3.5 hidden text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                  </AstroButton>
                </div>
              </div>
              <AstroButton id="print-btn" variant="outline" className="w-full" size="sm">
                Print QR code
              </AstroButton>
            </div>
          </>
        ) : (
          <div class="flex flex-col items-center justify-center py-8 px-4 text-center w-full h-full">
            <div class="p-3 rounded-full bg-muted mb-3">
              <svg class="w-6 h-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <p class="text-sm font-medium">Historical event</p>
            <p class="text-xs text-muted-foreground mt-1">Imported from past records — no QR code.</p>
          </div>
        )}
      </AstroCard>
    </div>

    <!-- Attendance Table -->
    <AstroCard className="overflow-hidden">
      <div class="p-6 border-b flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
        <div>
          <h2 class="text-lg font-semibold tracking-tight">Attendance</h2>
          <p class="text-sm text-muted-foreground mt-0.5">Verify check-in times and statuses.</p>
        </div>
        <AstroBadge variant="secondary">
          {attendance?.length || 0} registered
        </AstroBadge>
      </div>

      <div class="overflow-x-auto">
        <Table>
          <TableHeader>
            <TableRow className="hover:bg-transparent">
              <TableHead>Attendee</TableHead>
              <TableHead>Status</TableHead>
              <TableHead>Note</TableHead>
              <TableHead>Time</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {attendance?.map(record => {
              const roster = (record.team_members as any);
              const profileRow = (record.profiles as any);
              const name = roster?.full_name || profileRow?.full_name || 'Anonymous user';
              const email = roster?.email || profileRow?.email;
              const isPresent = record.status === 'present' || record.status === 'on_time';
              const isLate = record.status === 'late';
              const variant = isPresent ? 'success' : isLate ? 'warning' : 'destructive';
              const label = isPresent
                ? 'Present'
                : isLate
                  ? `Late +${formatLate(lateMinutesFor(record.checked_in_at))}`
                  : 'Absent';
              return (
                <TableRow>
                  <TableCell>
                    <div class="font-medium">{name}</div>
                    {email && <div class="text-xs text-muted-foreground">{email}</div>}
                  </TableCell>
                  <TableCell>
                    <AstroBadge variant={variant}>{label}</AstroBadge>
                  </TableCell>
                  <TableCell className="text-sm text-muted-foreground italic">
                    {record.note || '—'}
                  </TableCell>
                  <TableCell className="text-sm text-muted-foreground tabular-nums whitespace-nowrap">
                    {record.checked_in_at ? formatPacificTime(record.checked_in_at) : '—'}
                  </TableCell>
                </TableRow>
              );
            })}
            {(!attendance || attendance.length === 0) && (
              <TableRow className="hover:bg-transparent">
                <TableCell colSpan={4} className="py-16 text-center">
                  <div class="flex flex-col items-center">
                    <div class="p-3 rounded-full bg-muted mb-3">
                      <svg class="w-6 h-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    </div>
                    <p class="text-sm font-medium">No check-ins yet</p>
                    <p class="text-xs text-muted-foreground mt-1">Attendees will appear here as they check in.</p>
                  </div>
                </TableCell>
              </TableRow>
            )}
          </TableBody>
        </Table>
      </div>
    </AstroCard>

    <!-- Print-only container -->
    <div id="print-section" class="hidden">
      <h1 class="text-4xl font-bold mb-4">{event.title}</h1>
      <p class="text-xl text-muted-foreground mb-8">Scan to check in</p>
      <div class="bg-white p-6 rounded-3xl border border-black shadow-sm mb-6 flex justify-center items-center">
        {checkinUrl && <QRCode value={checkinUrl} client:load />}
      </div>
      <code class="text-sm font-mono text-muted-foreground break-all max-w-md">{checkinUrl}</code>
    </div>
  </main>
</Layout>

<style>
  @media print {
    body * {
      visibility: hidden;
    }
    #print-section, #print-section * {
      visibility: visible;
    }
    #print-section {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      height: 100%;
      display: flex !important;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background-color: white !important;
    }
  }
</style>

<script>
  import { toast } from "sonner";

  const copyBtn = document.getElementById("copy-btn");
  const copyIcon = document.getElementById("copy-icon");
  const checkIcon = document.getElementById("check-icon");

  if (copyBtn && copyIcon && checkIcon) {
    copyBtn.addEventListener("click", async () => {
      const url = copyBtn.getAttribute("data-url");
      if (!url) return;

      try {
        await navigator.clipboard.writeText(url);
        toast.success("Check-in URL copied to clipboard!");

        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");

        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      } catch (err) {
        console.error("Failed to copy text: ", err);
        toast.error("Failed to copy URL to clipboard");
      }
    });
  }

  const printBtn = document.getElementById("print-btn");
  if (printBtn) {
    printBtn.addEventListener("click", () => {
      window.print();
    });
  }
</script>
