---
import Layout from '../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../lib/supabase';
import AstroCard from '../../../components/AstroCard.astro';
import AstroButton from '../../../components/AstroButton.astro';
import { Input } from '../../../components/ui/input';
import { Label } from '../../../components/ui/label';
import { Textarea } from '../../../components/ui/textarea';
import { DateTimePicker } from '../../../components/DateTimePicker';
import { RecurrenceFields } from '../../../components/RecurrenceFields';
import { expandOccurrences, type RecurrenceFreq } from '../../../lib/recurrence';
import { ArrowLeft, AlertTriangle } from 'lucide-react';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title') as string;
  const description = formData.get('description') as string | null;
  const startsAtStr = formData.get('starts_at') as string;
  const opensAtStr = formData.get('checkin_opens_at') as string;
  const lateAfterStr = formData.get('late_after_at') as string;
  const closesAtStr = formData.get('checkin_closes_at') as string;

  const recurrenceFreq = (formData.get('recurrence_freq') as string | null) || '';
  const recurrenceTimezone = (formData.get('recurrence_timezone') as string | null) || 'UTC';
  const recurrenceByweekdayRaw = (formData.get('recurrence_byweekday') as string | null) || '';
  const recurrenceCountRaw = (formData.get('recurrence_count') as string | null) || '';
  const recurrenceUntilRaw = (formData.get('recurrence_until') as string | null) || '';

  if (!recurrenceFreq) {
    const qr_token = crypto.randomUUID();
    const { error } = await supabase.from('events').insert({
      title, description,
      starts_at: startsAtStr,
      checkin_opens_at: opensAtStr,
      late_after_at: lateAfterStr,
      checkin_closes_at: closesAtStr,
      qr_token,
      created_by: session.user.id,
    });
    if (!error) return Astro.redirect('/admin?toast=' + encodeURIComponent('Event created') + '&toastType=success');
    errorMsg = error.message;
  } else {
    const startsAt = new Date(startsAtStr);
    const opensAt = new Date(opensAtStr);
    const lateAfter = new Date(lateAfterStr);
    const closesAt = new Date(closesAtStr);

    const byweekday = recurrenceByweekdayRaw
      ? recurrenceByweekdayRaw.split(',').map(s => parseInt(s, 10)).filter(n => Number.isFinite(n))
      : undefined;
    const count = recurrenceCountRaw ? Math.max(1, parseInt(recurrenceCountRaw, 10)) : undefined;
    const until = recurrenceUntilRaw ? new Date(`${recurrenceUntilRaw}T00:00:00`) : undefined;

    if (!count && !until) {
      errorMsg = 'Pick an end date or a number of occurrences for the series.';
    } else {
      const occurrences = expandOccurrences({
        freq: recurrenceFreq as RecurrenceFreq,
        byweekday,
        count,
        until,
        startsAtLocal: startsAt,
        opensOffsetMs: opensAt.getTime() - startsAt.getTime(),
        lateOffsetMs: lateAfter.getTime() - startsAt.getTime(),
        closesOffsetMs: closesAt.getTime() - startsAt.getTime(),
        timezone: recurrenceTimezone,
      });

      if (occurrences.length === 0) {
        errorMsg = 'Recurrence settings produced zero occurrences. Check weekdays and end date.';
      } else {
        const { data: series, error: seriesErr } = await supabase
          .from('event_series')
          .insert({
            title,
            description,
            timezone: recurrenceTimezone,
            recurrence_freq: recurrenceFreq,
            recurrence_byweekday: byweekday && byweekday.length > 0 ? byweekday : null,
            recurrence_count: count ?? null,
            recurrence_until: recurrenceUntilRaw || null,
            created_by: session.user.id,
          })
          .select('id, qr_token')
          .single();

        if (seriesErr || !series) {
          errorMsg = seriesErr?.message ?? 'Failed to create series';
        } else {
          const rows = occurrences.map((o, idx) => ({
            title,
            description,
            starts_at: o.starts_at.toISOString(),
            checkin_opens_at: o.checkin_opens_at.toISOString(),
            late_after_at: o.late_after_at.toISOString(),
            checkin_closes_at: o.checkin_closes_at.toISOString(),
            qr_token: crypto.randomUUID(),
            created_by: session.user.id,
            series_id: series.id,
            occurrence_index: idx,
          }));
          const { error: insertErr } = await supabase.from('events').insert(rows);
          if (insertErr) {
            await supabase.from('event_series').delete().eq('id', series.id);
            errorMsg = insertErr.message;
          } else {
            return Astro.redirect(
              '/admin?toast=' +
                encodeURIComponent(`Created series with ${rows.length} occurrences`) +
                '&toastType=success'
            );
          }
        }
      }
    }
  }
}
---
<Layout title="New Event">
  <main class="max-w-2xl mx-auto p-6 md:p-8">
    <a href="/admin" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <ArrowLeft className="w-4 h-4" />
      Back to events
    </a>

    <AstroCard className="p-6 md:p-8">
      <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-balance">Create event</h1>
        <p class="text-muted-foreground mt-2 text-sm">Define the schedule and details for your event check-in.</p>
      </div>

      {errorMsg && (
        <div class="bg-destructive/10 border border-destructive/30 text-destructive text-sm p-3 rounded-2xl mb-6 flex items-center gap-2">
          <AlertTriangle className="w-4 h-4 shrink-0" />
          <span>{errorMsg}</span>
        </div>
      )}

      <form method="post" class="space-y-6" onsubmit="this.querySelector('button[type=submit]')?.setAttribute('disabled', 'true');">
        <div class="space-y-2">
          <Label htmlFor="title">Event title</Label>
          <Input id="title" name="title" type="text" required placeholder="Annual General Meeting 2026" />
        </div>

        <div class="space-y-2">
          <Label htmlFor="description">Description (optional)</Label>
          <Textarea id="description" name="description" placeholder="Provide context or instructions for attendees..." className="min-h-[100px] resize-none" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-6 border-t">
          <div class="space-y-2">
            <Label htmlFor="starts_at">Event starts at</Label>
            <DateTimePicker id="starts_at" name="starts_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_opens_at">Check-in opens</Label>
            <DateTimePicker id="checkin_opens_at" name="checkin_opens_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="late_after_at">Mark late after</Label>
            <DateTimePicker id="late_after_at" name="late_after_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_closes_at">Check-in closes</Label>
            <DateTimePicker id="checkin_closes_at" name="checkin_closes_at" required client:load />
          </div>
        </div>

        <RecurrenceFields client:load />

        <div class="flex justify-end gap-2 pt-6">
          <a href="/admin">
            <AstroButton type="button" variant="outline">Cancel</AstroButton>
          </a>
          <AstroButton type="submit">
            Create event
          </AstroButton>
        </div>
      </form>
    </AstroCard>
  </main>
</Layout>
