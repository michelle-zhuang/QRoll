---
import Layout from '../../../layouts/Layout.astro';
import { createSupabaseClient } from '../../../lib/supabase';
import AstroCard from '../../../components/AstroCard.astro';
import AstroButton from '../../../components/AstroButton.astro';
import { Input } from '../../../components/ui/input';
import { Label } from '../../../components/ui/label';
import { Textarea } from '../../../components/ui/textarea';
import { DateTimePicker } from '../../../components/DateTimePicker';
import { RecurrenceFields } from '../../../components/RecurrenceFields';
import { expandOccurrences, type RecurrenceFreq } from '../../../lib/recurrence';
import { ArrowLeft, AlertTriangle } from 'lucide-react';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

let errorMsg = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const title = formData.get('title') as string;
  const description = formData.get('description') as string | null;
  const startsAtStr = formData.get('starts_at') as string;
  const opensAtStr = formData.get('checkin_opens_at') as string;
  const lateAfterStr = formData.get('late_after_at') as string;
  const closesAtStr = formData.get('checkin_closes_at') as string;

  const recurrenceFreq = (formData.get('recurrence_freq') as string | null) || '';
  const recurrenceTimezone = (formData.get('recurrence_timezone') as string | null) || 'UTC';
  const recurrenceByweekdayRaw = (formData.get('recurrence_byweekday') as string | null) || '';
  const recurrenceCountRaw = (formData.get('recurrence_count') as string | null) || '';
  const recurrenceUntilRaw = (formData.get('recurrence_until') as string | null) || '';

  const geofenceEnabled = formData.get('geofence_enabled') === 'true';
  const latitude = formData.get('latitude') ? parseFloat(formData.get('latitude') as string) : null;
  const longitude = formData.get('longitude') ? parseFloat(formData.get('longitude') as string) : null;
  const radius = formData.get('geofence_radius_meters') ? parseInt(formData.get('geofence_radius_meters') as string, 10) : 100;

  if (!recurrenceFreq) {
    const qr_token = crypto.randomUUID();
    const { error } = await supabase.from('events').insert({
      title, description,
      starts_at: startsAtStr,
      checkin_opens_at: opensAtStr,
      late_after_at: lateAfterStr,
      checkin_closes_at: closesAtStr,
      qr_token,
      created_by: session.user.id,
      geofence_enabled: geofenceEnabled,
      latitude: geofenceEnabled ? latitude : null,
      longitude: geofenceEnabled ? longitude : null,
      geofence_radius_meters: geofenceEnabled ? radius : 100,
    });
    if (!error) return Astro.redirect('/admin?toast=' + encodeURIComponent('Event created') + '&toastType=success');
    errorMsg = error.message;
  } else {
    const startsAt = new Date(startsAtStr);
    const opensAt = new Date(opensAtStr);
    const lateAfter = new Date(lateAfterStr);
    const closesAt = new Date(closesAtStr);

    const byweekday = recurrenceByweekdayRaw
      ? recurrenceByweekdayRaw.split(',').map(s => parseInt(s, 10)).filter(n => Number.isFinite(n))
      : undefined;
    const count = recurrenceCountRaw ? Math.max(1, parseInt(recurrenceCountRaw, 10)) : undefined;
    const until = recurrenceUntilRaw ? new Date(`${recurrenceUntilRaw}T00:00:00`) : undefined;

    if (!count && !until) {
      errorMsg = 'Pick an end date or a number of occurrences for the series.';
    } else {
      const occurrences = expandOccurrences({
        freq: recurrenceFreq as RecurrenceFreq,
        byweekday,
        count,
        until,
        startsAtLocal: startsAt,
        opensOffsetMs: opensAt.getTime() - startsAt.getTime(),
        lateOffsetMs: lateAfter.getTime() - startsAt.getTime(),
        closesOffsetMs: closesAt.getTime() - startsAt.getTime(),
        timezone: recurrenceTimezone,
      });

      if (occurrences.length === 0) {
        errorMsg = 'Recurrence settings produced zero occurrences. Check weekdays and end date.';
      } else {
        const { data: series, error: seriesErr } = await supabase
          .from('event_series')
          .insert({
            title,
            description,
            timezone: recurrenceTimezone,
            recurrence_freq: recurrenceFreq,
            recurrence_byweekday: byweekday && byweekday.length > 0 ? byweekday : null,
            recurrence_count: count ?? null,
            recurrence_until: recurrenceUntilRaw || null,
            created_by: session.user.id,
            geofence_enabled: geofenceEnabled,
            latitude: geofenceEnabled ? latitude : null,
            longitude: geofenceEnabled ? longitude : null,
            geofence_radius_meters: geofenceEnabled ? radius : 100,
          })
          .select('id, qr_token')
          .single();

        if (seriesErr || !series) {
          errorMsg = seriesErr?.message ?? 'Failed to create series';
        } else {
          const rows = occurrences.map((o, idx) => ({
            title,
            description,
            starts_at: o.starts_at.toISOString(),
            checkin_opens_at: o.checkin_opens_at.toISOString(),
            late_after_at: o.late_after_at.toISOString(),
            checkin_closes_at: o.checkin_closes_at.toISOString(),
            qr_token: crypto.randomUUID(),
            created_by: session.user.id,
            series_id: series.id,
            occurrence_index: idx,
            geofence_enabled: geofenceEnabled,
            latitude: geofenceEnabled ? latitude : null,
            longitude: geofenceEnabled ? longitude : null,
            geofence_radius_meters: geofenceEnabled ? radius : 100,
          }));
          const { error: insertErr } = await supabase.from('events').insert(rows);
          if (insertErr) {
            await supabase.from('event_series').delete().eq('id', series.id);
            errorMsg = insertErr.message;
          } else {
            return Astro.redirect(
              '/admin?toast=' +
                encodeURIComponent(`Created series with ${rows.length} occurrences`) +
                '&toastType=success'
            );
          }
        }
      }
    }
  }
}
---
<Layout title="New Event">
  <main class="max-w-2xl mx-auto p-6 md:p-8">
    <a href="/admin" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <ArrowLeft className="w-4 h-4" />
      Back to events
    </a>

    <AstroCard className="p-6 md:p-8">
      <div class="mb-8">
        <h1 class="text-2xl font-bold tracking-tight text-balance">Create event</h1>
        <p class="text-muted-foreground mt-2 text-sm">Define the schedule and details for your event check-in.</p>
      </div>

      {errorMsg && (
        <div class="bg-destructive/10 border border-destructive/30 text-destructive text-sm p-3 rounded-2xl mb-6 flex items-center gap-2">
          <AlertTriangle className="w-4 h-4 shrink-0" />
          <span>{errorMsg}</span>
        </div>
      )}

      <form method="post" class="space-y-6" onsubmit="this.querySelector('button[type=submit]')?.setAttribute('disabled', 'true');">
        <div class="space-y-2">
          <Label htmlFor="title">Event title</Label>
          <Input id="title" name="title" type="text" required placeholder="Annual General Meeting 2026" />
        </div>

        <div class="space-y-2">
          <Label htmlFor="description">Description (optional)</Label>
          <Textarea id="description" name="description" placeholder="Provide context or instructions for attendees..." className="min-h-[100px] resize-none" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 pt-6 border-t">
          <div class="space-y-2">
            <Label htmlFor="starts_at">Event starts at</Label>
            <DateTimePicker id="starts_at" name="starts_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_opens_at">Check-in opens</Label>
            <DateTimePicker id="checkin_opens_at" name="checkin_opens_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="late_after_at">Mark late after</Label>
            <DateTimePicker id="late_after_at" name="late_after_at" required client:load />
          </div>
          <div class="space-y-2">
            <Label htmlFor="checkin_closes_at">Check-in closes</Label>
            <DateTimePicker id="checkin_closes_at" name="checkin_closes_at" required client:load />
          </div>
        </div>

        <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
        <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

        <div class="space-y-4 pt-6 border-t">
          <div class="flex items-center justify-between">
            <div class="space-y-0.5">
              <Label htmlFor="geofence_toggle" class="text-base font-semibold">Geofencing Verification</Label>
              <p class="text-xs text-muted-foreground">Restrict check-ins to a physical radius around the event venue.</p>
            </div>
            <button
              type="button"
              id="geofence-toggle"
              role="switch"
              aria-checked="false"
              class="relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 bg-muted-foreground/30"
            >
              <span class="sr-only">Enable geofencing</span>
              <span id="geofence-toggle-handle" class="pointer-events-none inline-block h-5 w-5 transform rounded-full bg-background shadow ring-0 transition duration-200 ease-in-out translate-x-0"></span>
            </button>
            <input type="hidden" name="geofence_enabled" id="geofence_enabled_val" value="false" />
          </div>

          <div id="geofence-panel" class="hidden space-y-4 mt-4 transition-all duration-200">
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <div class="space-y-2">
                <Label htmlFor="latitude">Latitude</Label>
                <Input id="latitude" name="latitude" type="number" step="any" placeholder="e.g. 47.6205" readOnly class="bg-muted/50" />
              </div>
              <div class="space-y-2">
                <Label htmlFor="longitude">Longitude</Label>
                <Input id="longitude" name="longitude" type="number" step="any" placeholder="e.g. -122.3493" readOnly class="bg-muted/50" />
              </div>
              <div class="space-y-2">
                <Label htmlFor="geofence_radius_meters">Radius (meters)</Label>
                <Input id="geofence_radius_meters" name="geofence_radius_meters" type="number" min="10" max="5000" defaultValue="100" />
              </div>
            </div>

            <div class="flex items-center gap-2">
              <AstroButton type="button" id="btn-use-current" variant="outline" size="sm" className="h-9 text-xs rounded-full">
                Pin to my current location
              </AstroButton>
              <span id="geo-status" class="text-xs text-muted-foreground"></span>
            </div>

            <div class="relative w-full h-[300px] rounded-2xl overflow-hidden border border-border" id="map-container">
              <div id="geofence-map" class="w-full h-full bg-muted/40 z-0"></div>
            </div>
            <p class="text-xs text-muted-foreground italic">Click anywhere on the map to change the geofence center location.</p>
          </div>
        </div>

        <script is:inline>
          document.addEventListener('DOMContentLoaded', () => {
            const toggle = document.getElementById('geofence-toggle');
            const handle = document.getElementById('geofence-toggle-handle');
            const hiddenVal = document.getElementById('geofence_enabled_val');
            const panel = document.getElementById('geofence-panel');

            const latInput = document.getElementById('latitude');
            const lonInput = document.getElementById('longitude');
            const radiusInput = document.getElementById('geofence_radius_meters');

            const useCurrentBtn = document.getElementById('btn-use-current');
            const geoStatus = document.getElementById('geo-status');

            let map = null;
            let marker = null;
            let circle = null;

            // Default coordinates: Space Needle (Seattle)
            let defaultLat = 47.6205;
            let defaultLon = -122.3493;
            let defaultRadius = parseInt(radiusInput.value, 10) || 100;

            function setToggleState(enabled) {
              if (enabled) {
                toggle.setAttribute('aria-checked', 'true');
                toggle.classList.remove('bg-muted-foreground/30');
                toggle.classList.add('bg-primary');
                handle.classList.remove('translate-x-0');
                handle.classList.add('translate-x-5');
                hiddenVal.value = 'true';
                panel.classList.remove('hidden');

                // Initialize Leaflet Map if not already initialized
                setTimeout(initMap, 50);
              } else {
                toggle.setAttribute('aria-checked', 'false');
                toggle.classList.remove('bg-primary');
                toggle.classList.add('bg-muted-foreground/30');
                handle.classList.remove('translate-x-5');
                handle.classList.add('translate-x-0');
                hiddenVal.value = 'false';
                panel.classList.add('hidden');
              }
            }

            toggle.addEventListener('click', () => {
              const enabled = toggle.getAttribute('aria-checked') === 'false';
              setToggleState(enabled);
            });

            function updateInputs(lat, lon) {
              latInput.value = lat.toFixed(6);
              lonInput.value = lon.toFixed(6);
            }

            function initMap() {
              if (map) {
                map.invalidateSize();
                return;
              }

              // Check if coordinates were empty
              if (!latInput.value || !lonInput.value) {
                updateInputs(defaultLat, defaultLon);
              } else {
                defaultLat = parseFloat(latInput.value);
                defaultLon = parseFloat(lonInput.value);
              }

              map = L.map('geofence-map').setView([defaultLat, defaultLon], 15);

              L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors'
              }).addTo(map);

              // Use custom divIcon to avoid asset-loading issues in frameworks
              const customIcon = L.divIcon({
                className: 'custom-div-icon',
                html: `<div class="w-6 h-6 rounded-full bg-[#2F2738] border-2 border-white shadow flex items-center justify-center"><div class="w-2.5 h-2.5 rounded-full bg-[#E4C1F9] animate-pulse"></div></div>`,
                iconSize: [24, 24],
                iconAnchor: [12, 12]
              });

              // Add marker
              marker = L.marker([defaultLat, defaultLon], { draggable: true, icon: customIcon }).addTo(map);

              // Add circle radius
              circle = L.circle([defaultLat, defaultLon], {
                color: '#E4C1F9',
                fillColor: '#E4C1F9',
                fillOpacity: 0.35,
                radius: defaultRadius
              }).addTo(map);

              // Marker drag event
              marker.on('drag', (e) => {
                const position = marker.getLatLng();
                updateInputs(position.lat, position.lng);
                circle.setLatLng(position);
              });

              // Map click event
              map.on('click', (e) => {
                const position = e.latlng;
                marker.setLatLng(position);
                circle.setLatLng(position);
                updateInputs(position.lat, position.lng);
              });

              // Radius change event
              radiusInput.addEventListener('input', () => {
                const r = parseInt(radiusInput.value, 10) || 100;
                circle.setRadius(r);
              });
            }

            // Geolocation handler
            useCurrentBtn.addEventListener('click', () => {
              geoStatus.textContent = 'Locating...';
              if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                  (position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;
                    geoStatus.textContent = 'Located!';
                    updateInputs(lat, lon);
                    if (map) {
                      map.setView([lat, lon], 16);
                      marker.setLatLng([lat, lon]);
                      circle.setLatLng([lat, lon]);
                    }
                  },
                  (error) => {
                    geoStatus.textContent = 'Error: ' + error.message;
                  },
                  { enableHighAccuracy: true, timeout: 5000 }
                );
              } else {
                geoStatus.textContent = 'Geolocation not supported';
              }
            });
          });
        </script>

        <RecurrenceFields client:load />

        <div class="flex justify-end gap-2 pt-6">
          <a href="/admin">
            <AstroButton type="button" variant="outline">Cancel</AstroButton>
          </a>
          <AstroButton type="submit">
            Create event
          </AstroButton>
        </div>
      </form>
    </AstroCard>
  </main>
</Layout>
