---
import Layout from '../../layouts/Layout.astro';
import { createSupabaseClient } from '../../lib/supabase';
import AstroCard from '../../components/AstroCard.astro';
import AstroButton from '../../components/AstroButton.astro';
import AstroBadge from '../../components/AstroBadge.astro';
import { Input } from '../../components/ui/input';
import { Label } from '../../components/ui/label';

const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (!session) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', session.user.id).single();
if (profile?.role !== 'admin') return Astro.redirect('/dashboard');

function toastRedirect(msg: string, type: 'success' | 'error' = 'success') {
  return Astro.redirect(`/admin/roster?toast=${encodeURIComponent(msg)}&toastType=${type}`);
}

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');

  if (action === 'create') {
    const full_name = (formData.get('full_name') || '').toString().trim();
    const email = (formData.get('email') || '').toString().trim() || null;
    if (!full_name) return toastRedirect('Name is required', 'error');
    const res = await supabase.from('roster_members').insert({ full_name, email });
    return toastRedirect(res.error ? res.error.message : `Added ${full_name}`, res.error ? 'error' : 'success');
  }
  if (action === 'update_email') {
    const id = formData.get('id')?.toString();
    const email = (formData.get('email') || '').toString().trim() || null;
    if (id) {
      const res = await supabase.from('roster_members').update({ email }).eq('id', id);
      return toastRedirect(
        res.error ? res.error.message : 'Email updated — auto-claim will run when that user signs up',
        res.error ? 'error' : 'success'
      );
    }
  }
  if (action === 'link') {
    const id = formData.get('id')?.toString();
    const userId = formData.get('user_id')?.toString() || null;
    if (id) {
      const res = await supabase
        .from('roster_members')
        .update({ claimed_user_id: userId })
        .eq('id', id);
      return toastRedirect(
        res.error ? res.error.message : userId ? 'Linked to account' : 'Unlinked from account',
        res.error ? 'error' : 'success'
      );
    }
  }
  if (action === 'delete') {
    const id = formData.get('id')?.toString();
    if (id) {
      const res = await supabase.from('roster_members').delete().eq('id', id);
      return toastRedirect(res.error ? res.error.message : 'Member deleted', res.error ? 'error' : 'success');
    }
  }
}

const [{ data: roster }, { data: profiles }] = await Promise.all([
  supabase.from('roster_members').select('*').order('full_name', { ascending: true }),
  supabase.from('profiles').select('id, email, full_name').order('full_name', { ascending: true }),
]);

const claimedCount = (roster || []).filter(r => r.claimed_user_id).length;
const unclaimedCount = (roster || []).length - claimedCount;
---
<Layout title="Roster">
  <main class="max-w-5xl mx-auto p-6 md:p-8">
    <a href="/admin" class="text-muted-foreground hover:text-foreground inline-flex items-center gap-2 mb-6 text-sm transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      Back to events
    </a>

    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-semibold tracking-tight">Roster</h1>
        <p class="text-muted-foreground mt-1 text-sm">Members who can attend events. Set an email to auto-link when they sign up, or link manually.</p>
      </div>
      <div class="flex items-center gap-2">
        <AstroBadge variant="success">{claimedCount} claimed</AstroBadge>
        <AstroBadge variant="outline">{unclaimedCount} unclaimed</AstroBadge>
      </div>
    </div>

    <!-- Add new member -->
    <AstroCard className="p-5 mb-6">
      <form method="post" class="grid grid-cols-1 sm:grid-cols-[1fr_1fr_auto] gap-3 items-end">
        <input type="hidden" name="_action" value="create" />
        <div class="space-y-1.5">
          <Label htmlFor="full_name">Full name</Label>
          <Input id="full_name" name="full_name" required placeholder="Jane Doe" />
        </div>
        <div class="space-y-1.5">
          <Label htmlFor="email">Email (optional)</Label>
          <Input id="email" name="email" type="email" placeholder="jane@example.com" />
        </div>
        <AstroButton type="submit">Add member</AstroButton>
      </form>
    </AstroCard>

    <!-- Roster list -->
    <AstroCard className="overflow-hidden mb-8">
      <div class="divide-y divide-border">
        {(roster || []).map(m => {
          const linkedProfile = profiles?.find(p => p.id === m.claimed_user_id);
          return (
            <details class="group border-b border-border last:border-0 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex items-center justify-between p-4 cursor-pointer hover:bg-muted/50 transition-all duration-200 ease-out hover:pl-5 list-none outline-none focus-visible:bg-muted/40">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="h-9 w-9 rounded-full bg-accent/20 text-accent-foreground flex items-center justify-center font-bold text-sm shrink-0">
                    {m.full_name?.charAt(0).toUpperCase()}
                  </div>
                  <div class="min-w-0">
                    <p class="text-sm font-semibold truncate text-foreground">{m.full_name}</p>
                    {linkedProfile ? (
                      <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
                        <p class="text-xs text-muted-foreground truncate">Linked: {linkedProfile.email}</p>
                      </div>
                    ) : (
                      <div class="flex items-center gap-1.5 mt-0.5">
                        <span class="h-1.5 w-1.5 rounded-full bg-amber-400"></span>
                        <p class="text-xs text-muted-foreground/60 truncate">Unclaimed {m.email ? `(${m.email})` : '(no email set)'}</p>
                      </div>
                    )}
                  </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <span class="text-xs text-muted-foreground group-open:hidden">Manage</span>
                  <span class="text-xs text-muted-foreground hidden group-open:inline">Close</span>
                  <svg class="w-4 h-4 text-muted-foreground group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </div>
              </summary>

              <div class="p-4 bg-muted/20 border-t border-border/50 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 items-end group-open:animate-slide-down origin-top">
                <form method="post" class="space-y-1.5">
                  <input type="hidden" name="_action" value="update_email" />
                  <input type="hidden" name="id" value={m.id} />
                  <Label htmlFor={`email-${m.id}`} className="text-xs text-muted-foreground">Auto-claim email</Label>
                  <div class="flex items-center gap-2">
                    <Input id={`email-${m.id}`} name="email" type="email" defaultValue={m.email || ''} placeholder="email@example.com" className="h-9 text-sm" />
                    <AstroButton type="submit" size="sm">Save</AstroButton>
                  </div>
                </form>

                <form method="post" class="space-y-1.5">
                  <input type="hidden" name="_action" value="link" />
                  <input type="hidden" name="id" value={m.id} />
                  <Label htmlFor={`link-${m.id}`} className="text-xs text-muted-foreground">Link account profile</Label>
                  <div class="flex items-center gap-2">
                    <select
                      id={`link-${m.id}`}
                      name="user_id"
                      class="flex h-9 w-full rounded-2xl border border-input bg-background px-3 py-1 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                    >
                      <option value="">— Unlinked —</option>
                      {profiles?.map(p => (
                        <option value={p.id} selected={m.claimed_user_id === p.id}>
                          {p.full_name || p.email}
                        </option>
                      ))}
                    </select>
                    <AstroButton type="submit" size="sm">Link</AstroButton>
                  </div>
                </form>

                <form method="post" class="flex justify-end lg:justify-start items-center" onsubmit={`return confirm('Delete ${m.full_name?.replace(/'/g, "\\'")}? Their attendance history will also be removed.')`}>
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={m.id} />
                  <AstroButton type="submit" variant="destructive" size="sm" className="w-full sm:w-auto mt-6">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6M1 7h22M9 7V4a1 1 0 011-1h4a1 1 0 011 1v3"></path></svg>
                    Remove member
                  </AstroButton>
                </form>
              </div>
            </details>
          );
        })}
        {(!roster || roster.length === 0) && (
          <div class="p-12 text-center text-muted-foreground text-sm">No roster members yet.</div>
        )}
      </div>
    </AstroCard>
  </main>
</Layout>
